public with sharing class ws_FutureCaseInTafnit {

    public Map<String, String> sendFutureCase(Appointment__c appt) {
        System.debug('ws_FutureCaseInTafnit.sendFutureCase...');                       
        String jsString = createJsonString(appt);
        return sendJsonToWS(jsString);
    }

    public static String createJsonString(Appointment__c appt) {   
        Integer numOfProcedures = 1;
        if(appt.Medical_Procedure2__r.Procedure_Code__c != null) {
            numOfProcedures = 2;
        }
        if(appt.Medical_Procedure3__r.Procedure_Code__c != null) {
            numOfProcedures = 3;
        }
        if(appt.Medical_Procedure4__r.Procedure_Code__c != null) {
            numOfProcedures = 4;
        }
        
        // add relavent paramteters that reqired for tafnit,
        // some of the mendatory parameters are generated by Ensemble
        JSONGenerator jsGen = JSON.createGenerator(true);
        jsGen.writeStartObject();
            jsGen.writeStringField('SysType','31');
            jsGen.writeStringField('MsgType','F');
            jsGen.writeStringField('PWinUser','TAFNIT_CREATE_FILE');
            jsGen.writeFieldName('PatientFile');
            jsGen.writeStartObject();
                jsGen.writeStringField('ClientNo', appt.Site__r.Site_code__c + '001'); 
                jsGen.writeStringField('PfIdType', appt.Patient_Account__r.ID_Type__c);
                jsGen.writeStringField('PfIdNo', appt.IDNumber__c);
                jsGen.writeStringField('PfEntryDate', String.valueof(appt.Appointment_Date_Time__c));
                //jsGen.writeStringField('PfSickFund',appt.PayerFactor__r.InsuranceCode__c);
                jsGen.writeStringField('PfInsurenceCode','2');
                jsGen.writeStringField('PfEmergency','N');
                jsGen.writeStringField('PfConfidential','N');
                jsGen.writeStringField('PConfidential','N');
                jsGen.writeStringField('PfTreatType','1');
                if(appt.Number_of_referral__c != null){
                    jsGen.writeStringField('PfMedrefNo', appt.Number_of_referral__c); // make sure
                    jsGen.writeStringField('PfMedrefDate', String.valueof(appt.Date_of_referral__c));
                }

                jsGen.writeFieldName('PatientFileActivities');
                jsGen.writeStartArray();
                    for(Integer j = 1; j < numOfProcedures + 1; j++ ){
                        jsGen.writeStartObject();
                            jsGen.writeFieldName('PatientFileActivity');
                            jsGen.writeStartObject();
                                jsGen.writeStringField('PfaClientNo', appt.Site__r.Site_code__c + '001'); 
                                jsGen.writeStringField('PfaQut','1');
                                switch on j {
                                        when 1 {
                                            jsGen.writeStringField('ActivityCode', appt.Medical_Procedure__r.Procedure_Code__c);
                                            jsGen.writeStringField('PfaActivityType', 'ר');
                                            jsGen.writeStringField('DoctorType', 'ר');
                                        }  
                                        when 2 { 
                                            jsGen.writeStringField('ActivityCode',appt.Medical_Procedure2__r.Procedure_Code__c);
                                            jsGen.writeStringField('PfaActivityType','מ');
                                            jsGen.writeStringField('DoctorType','מ');
                                        }
                                        when 3 { 
                                            jsGen.writeStringField('ActivityCode', appt.Medical_Procedure3__r.Procedure_Code__c);
                                            jsGen.writeStringField('PfaActivityType', 'מ');
                                            jsGen.writeStringField('DoctorType', 'מ');
                                        }
                                        when 4 {
                                            jsGen.writeStringField('ActivityCode', appt.Medical_Procedure4__r.Procedure_Code__c);
                                            jsGen.writeStringField('PfaActivityType', 'מ');
                                            jsGen.writeStringField('DoctorType', 'מ');
                                        }
                                }

                                jsGen.writeStringField('DoctorCodeType', '3');
                                jsGen.writeStringField('PfaDoctor', appt.Doctor_Account__r.Doctor_Code__c); // 
                                //jsGen.writeStringField('PfaDoctor','18667'); 
                                jsGen.writeFieldName('PatientFilePayers');
                                jsGen.writeStartArray();
                                    jsGen.writeStartObject();
                                        jsGen.writeFieldName('PatientFilePayer');
                                        jsGen.writeStartObject();
                                            jsGen.writeStringField('PayerNo', appt.PayerFactor__r.InsuranceCode__c);
                                            if(appt.Deductibles__c!=null){
                                                jsGen.writeStringField('PfpSumSelf', String.valueof(appt.Deductibles__c));
                                            }
                                            jsGen.writeStringField('PfpExtNo', appt.Number_of_commitment__c);
                                            jsGen.writeStringField('PfpDate', String.valueof(appt.Date_of_commitment__c));
                                            jsGen.writeStringField('PfpExtDate', String.valueof(appt.Expiration_date_commitment__c));
                                            jsGen.writeStringField('PfpType', 'ר');
                                            jsGen.writeStringField('PfpCoinSelf', 'NIS');
                                            jsGen.writeStringField('PfpCoin', 'NIS');
                                        jsGen.writeEndObject();
                                    jsGen.writeEndObject();
                                jsGen.writeEndArray();
                            jsGen.writeEndObject();
                        jsGen.writeEndObject();   
                    }
                jsGen.writeEndArray();
            jsGen.writeEndObject();
        jsGen.writeEndObject();
        return jsGen.getAsString();
    }
    
    public static Map<String, String> sendJsonToWS(String messBody) {
        ENV__c env = ENV__c.getInstance();
        Http http = new Http();
        HttpRequest request = new HttpRequest();
          
        request.setMethod('POST');
        request.setHeader('Content-Type', 'application/json');
        request.setEndpoint('callout:Ensemble_Rest_'+ env.Env_value__c +'/TafnitHomeAdmission/futureCase/CreateFutureCase');
        request.setTimeout(25000);
        request.setBody(messBody);
        
        try {
            Map<String, String> resMap = new  Map<String, String>();
            HttpResponse response = http.send(request);           
            if (response.getStatusCode() != 200) {
                System.debug('The status code returned was not expected: ' + response.getStatusCode() + ' ' + response.getStatus());                
            } else {
                System.debug(response.getBody());
                Map<String, Object> results = (Map<String, Object>) JSON.deserializeUntyped(response.getBody());                
                if ((String)results.get('ResultStatus') == '0') {
                    Integer fileNo = (Integer)results.get('FileNo');
                    resMap.put('FileNo', String.valueOf(fileNo));                
                } else{                                         
                    List<Object> ErrCodes = (List<Object>)results.get('ErrCodes');
                    System.debug('ErrCodes size : ' + ErrCodes.size());
                    for (Integer i=0; i < ErrCodes.size(); i++) {
                        Map<String,Object> ec = (Map<String,Object>)ErrCodes[i];
                        if ((String)ec.get('Message')!= null) {
                        resMap.put('Message', (String)ec.get('Message'));    
                        }     
                    }
                    System.debug('Error from tafnit : result status is not equall to 0');                   
                }                                                
            }
            return resMap;
        } catch (exception e) {
            System.debug('Error: An exception has been encountered while calling out to FutureCase:' + e.getMessage());
            return null;
        }
    }
}