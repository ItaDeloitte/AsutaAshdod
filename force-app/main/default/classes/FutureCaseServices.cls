public class FutureCaseServices {
    private static Integer queueCounter = 0;
    public static void sendFutureCase(Set<Id> futureCaseIdSet) {
        System.debug('FutureCaseServices.sendFutureCase...');
        // query for all the required data that needed for tafnit
        List<Appointment__c> appointmentList = [SELECT Id,
                                                    Patient_Account__r.ID_Type__c,
                                                    IDNumber__c,
                                                    Number_of_referral__c,
                                                    Date_of_referral__c,
                                                    Appointment_Date_Time__c, //
                                                    Date_of_appointment__c, //
                                                    Expiration_date_commitment__c,
                                                    Number_of_commitment__c,
                                                    Date_of_commitment__c,
                                                    Patient_Account__r.PersonMobilePhone,
                                                    Patient_Account__r.FirstName,
                                                    Patient_Account__r.LastName,
                                                    Patient_Account__r.PersonBirthdate,
                                                    Patient_Account__r.Gender__c,
                                                    Patient_Account__r.PersonMailingCity,//
                                                    Patient_Account__r.PersonMailingStreet,//
                                                    PayerFactor__r.InsuranceCode__c,
                                                    Doctor_Account__r.FirstName,
                                                    Doctor_Account__r.LastName,
                                                    Doctor_Account__r.Doctor_Code__c,
                                                    Doctor_Account__r.doctor_degree__c,
                                                    Doctor_Account__r.Name,
                                                    Medical_Procedure__r.Procedure_Code__c,
                                                    Medical_Procedure2__r.Procedure_Code__c,
                                                    Medical_Procedure3__r.Procedure_Code__c,
                                                    Medical_Procedure4__r.Procedure_Code__c,
                                                    Payment_to_Doctor__c,
                                                    Site__r.Site_code__c,
                                                    Deductibles__c
                                                    FROM Appointment__c
                                                    WHERE Id IN:futureCaseIdSet];

        //List<String> messageBodyList = new List<String>();
        //Map<Id,List<String>> messageBodyList = new Map<Id,List<String>>();
        List<Map<Id,String>> messageBodyList = new List<Map<Id,String>>();
        Map<Id,String> messageMap = new Map<Id,String>();
        
        for (Integer i = 0; i<appointmentList.Size(); i++) {
            
            JSONGenerator jsGen = JSON.createGenerator(true);
            Integer numOfProcedures = 1;
            if(appointmentList[i].Medical_Procedure2__r.Procedure_Code__c != null){
                numOfProcedures = 2;
            }
            if(appointmentList[i].Medical_Procedure3__r.Procedure_Code__c != null){
                numOfProcedures = 3;
            }
            if(appointmentList[i].Medical_Procedure4__r.Procedure_Code__c != null){
                numOfProcedures = 4;
            }
            
            // add relavent paramteters that reqired for tafnit,
            // some of the mendatory parameters are generated by Ensemble
             jsGen.writeStartObject();
                
                jsGen.writeStringField('SysType','31');
                jsGen.writeStringField('MsgType','F');
                jsGen.writeStringField('PWinUser','TAFNIT_CREATE_FILE');
                jsGen.writeFieldName('PatientFile');
                jsGen.writeStartObject();
                jsGen.writeStringField('ClientNo',appointmentList[i].Site__r.Site_code__c+'001'); 
                jsGen.writeStringField('PfIdType',appointmentList[i].Patient_Account__r.ID_Type__c);
                jsGen.writeStringField('PfIdNo',appointmentList[i].IDNumber__c);
                jsGen.writeStringField('PfEntryDate',String.valueof(appointmentList[i].Appointment_Date_Time__c));
                //jsGen.writeStringField('PfSickFund',appointmentList[i].PayerFactor__r.InsuranceCode__c);
                jsGen.writeStringField('PfInsurenceCode','2');
                jsGen.writeStringField('PfEmergency','N');
                jsGen.writeStringField('PfConfidential','N');
                jsGen.writeStringField('PConfidential','N');
                jsGen.writeStringField('PfTreatType','1');
                if(appointmentList[i].Number_of_referral__c!=null){
                    jsGen.writeStringField('PfMedrefNo',appointmentList[i].Number_of_referral__c); // make sure
                    jsGen.writeStringField('PfMedrefDate',String.valueof(appointmentList[i].Date_of_referral__c));
                }

                jsGen.writeFieldName('PatientFileActivities');
                jsGen.writeStartArray();
                for(Integer j=1; j<numOfProcedures+1;j++){
                    jsGen.writeStartObject();
                    jsGen.writeFieldName('PatientFileActivity');
                    jsGen.writeStartObject();
                        jsGen.writeStringField('PfaClientNo',appointmentList[i].Site__r.Site_code__c+'001'); 
                        jsGen.writeStringField('PfaQut','1');
                        switch on j {
                                when 1 {
                                    jsGen.writeStringField('ActivityCode',appointmentList[i].Medical_Procedure__r.Procedure_Code__c);
                                    jsGen.writeStringField('PfaActivityType','ר');
                                    jsGen.writeStringField('DoctorType','ר');
                                }  
                                when 2 { 
                                    jsGen.writeStringField('ActivityCode',appointmentList[i].Medical_Procedure2__r.Procedure_Code__c);
                                    jsGen.writeStringField('PfaActivityType','מ');
                                    jsGen.writeStringField('DoctorType','מ');
                                }
                                when 3 { 
                                    jsGen.writeStringField('ActivityCode',appointmentList[i].Medical_Procedure3__r.Procedure_Code__c);
                                    jsGen.writeStringField('PfaActivityType','מ');
                                    jsGen.writeStringField('DoctorType','מ');
                                }
                                when 4 {
                                    jsGen.writeStringField('ActivityCode',appointmentList[i].Medical_Procedure4__r.Procedure_Code__c);
                                    jsGen.writeStringField('PfaActivityType','מ');
                                    jsGen.writeStringField('DoctorType','מ');
                                }

                            }

                        jsGen.writeStringField('DoctorCodeType','3');
                        jsGen.writeStringField('PfaDoctor',appointmentList[i].Doctor_Account__r.Doctor_Code__c); // 
                        //jsGen.writeStringField('PfaDoctor','18667'); 
                        jsGen.writeFieldName('PatientFilePayers');
                        jsGen.writeStartArray();
                            jsGen.writeStartObject();
                            jsGen.writeFieldName('PatientFilePayer');
                            jsGen.writeStartObject();
                                jsGen.writeStringField('PayerNo',appointmentList[i].PayerFactor__r.InsuranceCode__c);
                                if(appointmentList[i].Deductibles__c!=null){
                                    jsGen.writeStringField('PfpSumSelf',String.valueof(appointmentList[i].Deductibles__c));
                                }
                                jsGen.writeStringField('PfpExtNo',appointmentList[i].Number_of_commitment__c);
                                jsGen.writeStringField('PfpDate',String.valueof(appointmentList[i].Date_of_commitment__c));
                                jsGen.writeStringField('PfpExtDate',String.valueof(appointmentList[i].Expiration_date_commitment__c));
                                jsGen.writeStringField('PfpType','ר');
                                jsGen.writeStringField('PfpCoinSelf','NIS');
                                jsGen.writeStringField('PfpCoin','NIS');
                            jsGen.writeEndObject();
                        jsGen.writeEndObject();
                    jsGen.writeEndArray();
                jsGen.writeEndObject();
            jsGen.writeEndObject();   
                }

            jsGen.writeEndArray();
            jsGen.writeEndObject();
            jsGen.writeEndObject();
            
                
            messageMap.put(appointmentList[i].Id,jsGen.getAsString());
            messageBodyList.add(messageMap);
           //messageBodyList.put(jsGen,appointmentList[i].Id); // for map
            //messageBodyList.add(jsGen.getAsString());
            if(math.mod(i+1, 100) == 0){
                checkLimit(messageBodyList);
                messageBodyList.Clear();
            }
            else if(i+1 == appointmentList.Size()){
                checkLimit(messageBodyList);
            } 
        }
    }
    // MAP<Id,List<String>>


    public static void checkLimit(List<Map<Id,String>> messageBodyList){
        if(queueCounter > 1) return;
            
        //check to ensure a callout can be performed using the Limits class. 
        //This is 100 callouts per execution as of Spring 16 release
        if (Limits.getCallouts() >= Limits.getLimitCallouts()) {
            System.debug('Maximum number of callouts has been reached.');
            
        } 
        else{
            ID jobID = System.enqueueJob(new ws_FutureCase(messageBodyList));
            queueCounter++;
        } 
    } 

