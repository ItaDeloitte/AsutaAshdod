<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IsAppBefore14__c</fullName>
    <description>Checks if a given appointment is before 2 pm</description>
    <formula>IF( Time_of_appointment__c  &lt; TIMEVALUE(&quot;14:00:00.00&quot;)+($User.TimeZoneOffset__c /24), true, false)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Is App Before 14</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
