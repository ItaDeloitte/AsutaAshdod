<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Details_is_mandatory</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL( Approved_by_anesthesiologist__c , &quot;False&quot;), 
    ISBLANK(Details__c))</errorConditionFormula>
    <errorDisplayField>Details__c</errorDisplayField>
    <errorMessage>נא להזין פירוט</errorMessage>
</ValidationRule>
