<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Missing_documents_is_mandatory</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
ISPICKVAL( Have_all_the_documents_been_received__c  , &quot;2&quot;),
ISBLANK(Missing_documents__c))</errorConditionFormula>
    <errorDisplayField>Missing_documents__c</errorDisplayField>
    <errorMessage>נא לפרט אילו מסמכים חסרים</errorMessage>
</ValidationRule>
