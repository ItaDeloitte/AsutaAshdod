<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PhoneCheck_number_format</fullName>
    <active>true</active>
    <description>Checks that the phone number is in number format</description>
    <errorConditionFormula>!ISNUMBER( phone__c) &amp;&amp;
RecordType.DeveloperName  == &apos;Supplier&apos;
&amp;&amp;!ISBLANK( phone__c)</errorConditionFormula>
    <errorDisplayField>phone__c</errorDisplayField>
    <errorMessage>!נא לוודא שהזנת במספר טלפון מספרים בלבד</errorMessage>
</ValidationRule>
