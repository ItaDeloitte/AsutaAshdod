<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>BankAccountCheck_number_format</fullName>
    <active>true</active>
    <description>Checks that the bank account number is in number format</description>
    <errorConditionFormula>!ISNUMBER(  BankAccount_Number__c ) &amp;&amp;
!ISBLANK(BankAccount_Number__c )&amp;&amp;
RecordType.DeveloperName  == &apos;Supplier&apos;</errorConditionFormula>
    <errorDisplayField>BankAccount_Number__c</errorDisplayField>
    <errorMessage>!נא לוודא שהזנת במספר חשבון בנק מספרים בלבד</errorMessage>
</ValidationRule>
