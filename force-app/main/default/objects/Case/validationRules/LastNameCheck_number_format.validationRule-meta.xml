<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>LastNameCheck_number_format</fullName>
    <active>true</active>
    <description>Checks that the last name is in text format</description>
    <errorConditionFormula>NOT(
REGEX(    Supplier_Last_Name__c  ,&quot;([a-zA-Z-א-ת&apos; ])*&quot;))
&amp;&amp; RecordType.DeveloperName  == &apos;Supplier&apos; &amp;&amp;
!ISBLANK(Supplier_Last_Name__c  )</errorConditionFormula>
    <errorDisplayField>Supplier_Last_Name__c</errorDisplayField>
    <errorMessage>נא לוודא ששם משפחה מכיל אותיות בלבד!</errorMessage>
</ValidationRule>
