<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Interface_Handled</fullName>
    <active>true</active>
    <description>עבור נרמר</description>
    <errorConditionFormula>AND(
    ISPICKVAL(sub_case_subject__c, &apos;ממשק נכשל&apos;),
    ISPICKVAL(Interface_handled__c, &quot;&quot;)
)</errorConditionFormula>
    <errorDisplayField>Interface_handled__c</errorDisplayField>
    <errorMessage>האם הממשק טופל?</errorMessage>
</ValidationRule>
