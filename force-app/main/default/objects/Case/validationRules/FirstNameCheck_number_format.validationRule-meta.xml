<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>FirstNameCheck_number_format</fullName>
    <active>true</active>
    <description>Checks that the first name is in text format</description>
    <errorConditionFormula>NOT(
REGEX(  First_Name__c  ,&quot;([a-zA-Z-א-ת&apos; ])*&quot;))
&amp;&amp; RecordType.DeveloperName  == &apos;Supplier&apos; &amp;&amp; !
!ISBLANK(First_Name__c  )</errorConditionFormula>
    <errorDisplayField>First_Name__c</errorDisplayField>
    <errorMessage>נא לוודא ששם פרטי מכיל אותיות בלבד!</errorMessage>
</ValidationRule>
