<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_Campaign</fullName>
    <active>true</active>
    <description>Campaign is required when Create_Lead is enabled.</description>
    <errorConditionFormula>AND(
     Create_Lead__c = TRUE,
    ISBLANK(Campaign__c)
)</errorConditionFormula>
    <errorDisplayField>Campaign__c</errorDisplayField>
    <errorMessage>Campaign is required when Create Lead  is enabled</errorMessage>
</ValidationRule>
