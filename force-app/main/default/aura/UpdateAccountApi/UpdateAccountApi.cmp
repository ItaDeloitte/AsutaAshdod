<aura:component extends="c:BaseComponent"
  implements="flexipage:availableForAllPageTypes,force:hasRecordId,force:lightningQuickActionWithoutHeader"
  access="global">

  <!-- attrs -->
  <aura:attribute name="recordId" type="String" />
  <aura:attribute name="isAutoUpdate" type="Boolean" default="true" />
  <!-- handlers -->
  <!-- events -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />
  <!-- methods -->
  <aura:method name="update" action="{!c.onUpdate}">
    <aura:attribute name="accountId" type="String" />
  </aura:method>

  <div>
    <c:Spinner isLoading="{!v.isLoading}" isGlobal="true" />
  </div>


</aura:component>