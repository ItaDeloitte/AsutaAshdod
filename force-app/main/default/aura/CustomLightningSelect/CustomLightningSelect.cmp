<aura:component extends="c:BaseComponent">
  <!-- attrs -->
  <aura:attribute name="name" type="String" default="" />
  <aura:attribute name="label" type="String" default="" />
  <aura:attribute name="options" type="List" default="[]" />
  <aura:attribute name="value" type="String" default="" />
  <aura:attribute name="requried" type="Boolean" default="false" />
  <aura:attribute name="disabled" type="Boolean" default="false" />
  <aura:attribute name="validity" type="Object" />
  <!-- handlers -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />
  <aura:handler name="destroy" value="{!this}" action="{!c.onDestroy}" />
  <!-- events -->
  <aura:registerEvent name="onchange" type="c:GenericComponentEvent" />
  <!-- methods -->
  <aura:method name="showHelpMessageIfInvalid" action="{!c.onShowHelpMessageIfInvalid}">
  </aura:method>


  <div>
    <lightning:select aura:id="select" name="{!v.name}" label="{!v.label}" required="{!v.required}"
      onchange="{!c.onChangeSelect}" validity="{!v.validity}" value="{!v.value}">
      <option value="" disabled="true"></option>
      <aura:iteration items="{!v.options}" var="option" indexVar="_index">
        <option value="{!option.value}">{!option.label}</option>
      </aura:iteration>
    </lightning:select>
  </div>
</aura:component>