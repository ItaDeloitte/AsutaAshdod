<aura:component extends="c:BaseComponent" implements="flexipage:availableForAllPageTypes,force:hasRecordId"
  access="global">
  <!-- attrs -->
  <aura:attribute name="recordId" type="String" default="" />
  <aura:attribute name="isLoading" type="Boolean" default="false" />
  <aura:attribute name="isAvailable" type="Boolean" default="true" />
  <aura:attribute name="sobjectType" type="String" default="" />
  <aura:attribute name="label" type="String" default="Cancel appointment" />
  <!-- handlers -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />
  <aura:handler name="destroy" value="{!this}" action="{!c.onDestroy}" />
  <aura:handler event="force:refreshView" action="{!c.onInit}" />
  <!-- events -->
  <!-- methods -->

  <aura:if isTrue="{!v.isAvailable}">
    <lightning:overlayLibrary aura:id="overlayLib" />
    <lightning:button label="{!v.label}" variant="neutral" onclick="{!c.onCancelClick}" disabled="{!v.isLoading}" />
  </aura:if>

</aura:component>