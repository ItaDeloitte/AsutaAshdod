<aura:component extends="c:AppointmentsBase" implements="flexipage:availableForAllPageTypes,force:hasRecordId"
                access="global">
  <!-- attrs -->
  <aura:attribute name="isAvailable" type="Boolean" default="false" />
  <aura:attribute name="recordId" type="String" default="" />
  <aura:attribute name="componentHeader" type="String" default="Surgeries Appointment Creation" />
  <aura:attribute name="caseRTDeveloperName" type="String" default="Surgery" />
  <aura:attribute name="appointmentRTDeveloperName" type="String" default="Surgeries" />

  <aura:attribute name="nextLabel" type="String" default="Next" />
  <!-- handlers -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />

  <!-- events -->
  <!-- methods -->

  <aura:if isTrue="{!v.isAvailable}">
    <!--<div class="slds-card">-->
    <lightning:overlayLibrary aura:id="overlayLib" />
    <!--<header class="slds-card__header slds-grid">
        <div class="slds-media slds-media_center slds-has-flexi-truncate">
          <div class="slds-media__figure">
            <lightning:icon iconName="standard:service_appointment" size="small" />
          </div>
          <div class="slds-media__body slds-truncate">
            <span class="slds-text-heading_small card-title">
              {!v.componentHeader}
            </span>
          </div>
        </div>
      </header>
      <div class="slds-card__body">
        <div class="slds-card__body_inner">
          <div class="slds-text-align_center">-->
    <span class="single-btn-wrapper">
      <lightning:button label="{!v.nextLabel}" onclick="{!c.createAppointment}" />
    </span>
    <!--</div>
        </div>
      </div>
    </div>-->
  </aura:if>


</aura:component>