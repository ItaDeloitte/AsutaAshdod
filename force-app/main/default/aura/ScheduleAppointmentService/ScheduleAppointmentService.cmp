<aura:component extends="c:BaseComponent">
  <!-- attrs -->
  <aura:attribute name="service" type="Map" default="{}" />
  <!-- handlers -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />
  <aura:handler name="destroy" value="{!this}" action="{!c.onDestroy}" />
  <!-- events -->
  <!-- methods -->
  <aura:method name="getService" action="{!c.onGetService}">
  </aura:method>


</aura:component>