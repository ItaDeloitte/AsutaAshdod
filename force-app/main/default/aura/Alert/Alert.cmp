<aura:component access="global" extends="c:BaseComponent">
  <!-- attrs -->
  <aura:attribute name="class" type="String" default="" />
  <!-- themes:
    default, shade, inverse, alt-inverse, success, info, warning, error, offline
  -->
  <aura:attribute name="theme" type="String" default="default" />
  <aura:attribute name="texture" type="Boolean" default="false" />
  <aura:attribute name="closeable" type="Boolean" default="false" />
  <!-- handlers -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />

  <!-- events -->
  <aura:registerEvent name="closed" type="c:GenericComponentEvent" />

  <div class="{!v.class}">
    <div class="{!join(' ',
    'slds-notify slds-notify_alert slds-m-bottom_small',
    'slds-theme_'+v.theme,
    v.texture?'slds-theme_alert-texture':''
    )}" role="alert">
      <span class="slds-assistive-text">{!v.theme}</span>
      {!v.body}
      <aura:if isTrue="{!v.closeable}">
        <div class="slds-notify__close">
          <lightning:buttonIcon iconName="utility:close" variant="{!v.theme=='default'?'bare':'bare-inverse'}"
            onclick="{! c.onClose }" alternativeText="Close" />
        </div>
      </aura:if>
    </div>
  </div>
</aura:component>