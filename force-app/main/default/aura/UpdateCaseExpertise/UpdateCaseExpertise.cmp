<aura:component extends="c:BaseComponent" implements="flexipage:availableForAllPageTypes,force:hasRecordId" access="global">
  <!-- attrs -->
  <aura:attribute name="isLoading" type="Boolean" default="false" />
  <aura:attribute name="selectedExpertiseId" type="String" default="" />
  <aura:attribute name="selectedSubExpertiseId" type="String" default="" />
  <aura:attribute name="selectedProcedureId" type="String" default="" />
  <aura:attribute name="serverError" type="String" default="" />
  <!-- handlers -->
  <aura:handler name="init" value="{!this}" action="{!c.onInit}" />
  <aura:handler name="destroy" value="{!this}" action="{!c.onDestroy}" />
  <aura:handler name="render" value="{!this}" action="{!c.onRender}" />
  <!-- <aura:handler name="change" value="{!v.selectedExpertiseId}" action="{!c.expertiseIdChanged}"/> -->
  <!-- <aura:handler name="change" value="{!v.selectedSubExpertiseId}" action="{!c.subExpertiseIdChanged}"/> -->
  <!-- events -->
  <!-- methods -->

  <div class="slds-card">
    <header class="slds-card__header slds-grid">
      <div class="slds-media slds-media_center slds-has-flexi-truncate">
        <div class="slds-media__figure">
          <lightning:icon iconName="standard:contact" size="small" />
        </div>
        <div class="slds-media__body slds-truncate">
          <span class="slds-text-heading_small card-title">
            {!$Label.c.Change_Case_Expertise}
          </span>
        </div>
      </div>
    </header>
    <div class="slds-card__body">
      <div class="slds-card__body_inner">
        <div class="">
          <c:BaseAutocomplete aura:id="formFieldExpertice" label="{!$Label.c.Select_Expertise}" value="{!v.selectedExpertiseId}"
            onsearch="{!c.onSearchExpertise}" oninitsearch="{!c.onSearchExpertise}" onchange="{!c.expertiseIdChanged}" required="false" placeholder="{!$Label.c.Search_expertise}" />
        </div>
        <div class="">
          <c:BaseAutocomplete aura:id="formFieldSubExpertise" label="{!$Label.c.Select_Sub_Expertise}" value="{!v.selectedSubExpertiseId}"
            onsearch="{!c.onSearchSubExpertise}" oninitsearch="{!c.onSearchSubExpertise}" onchange="{!c.subExpertiseIdChanged}" required="false" placeholder="{!$Label.c.Search_sub_expertise}" />
        </div>
        <div class="">
          <c:BaseAutocomplete aura:id="formFieldProcedure" label="{!$Label.c.Select_Medical_Procedure}" value="{!v.selectedProcedureId}"
            onsearch="{!c.onSearchProcedure}" oninitsearch="{!c.onSearchProcedure}" required="false" placeholder="{!$Label.c.Search_medical_procedure}" />
        </div>
        <div class="slds-p-top_medium">
          <aura:if isTrue="{!v.serverError}">
            <c:Alert theme="error">
              <div>
                <aura:unescapedHtml value="{!v.serverError}" />
              </div>
            </c:Alert>
          </aura:if>
        </div>
        <div class="slds-p-top_medium slds-text-align_right">
          <lightning:button type="button" label="{!$Label.c.Change}" onclick="{!c.onSubmit}"
            disabled="{!v.isLoading}" />
        </div>
      </div>
      <c:Spinner isLoading="{!v.isLoading}" size="small" />
    </div>
  </div>
</aura:component>