<apex:page standardController="File__c" extensions="ShowDocFromPortal" lightningStylesheets="true" sidebar="false" showHeader="false">



    <a onclick="showFile()" class="docLink">Show the document</a>
    <iframe id="_iframe" class="_iframe_close"></iframe>

    
    
    <style type='text/css'>

        body::-webkit-scrollbar { 
            display: none; 
        }

        ._iframe_open {
            height: 50rem;
            width: 100%;
            display: block;
        }

        ._iframe_close {
            height: 0;
            width: 0;
            display: none;
        }

        .docLink{
            cursor: pointer;
        }

        .custPopup{
            background-color: white;
            border-width: 2px;
            border-style: solid;
            z-index: 9999;
            left: 50%;
            padding:10px;
            position: absolute;
            width: 500px;
            margin-left: -250px;
            top:100px;
        }
        .popupBackground{
            background-color:black;
            opacity: 0.20;
            filter: alpha(opacity = 20);
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 9998;
        }

    </style>

    <script type="text/javascript">
    
        var url = JSON.parse('{!JSENCODE(urlJSON)}');
        var idNumber = JSON.parse('{!JSENCODE(idNumberJSON)}');

        function showFile(){
            debugger
            if(url != '' && idNumber != '' && url != undefined && idNumber != undefined){
                Visualforce.remoting.Manager.invokeAction(
                    '{!$RemoteAction.ShowDocFromPortal.getPDF}',
                    url,
                    idNumber,
                    function(result, event){
                        if (event.status) {                        
                            var pdf = result;
                            document.getElementById('_iframe').classList.remove('_iframe_close');
                            document.getElementById('_iframe').classList.add('_iframe_open');
                            document.getElementById('_iframe').setAttribute('src', "data:application/pdf;base64,"+pdf+'#toolbar=0');
                        } 
                    }, 
                    {escape: true}
                );
            }
        }   

          
    </script>

</apex:page>