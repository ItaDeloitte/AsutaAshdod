    <decisions>
        <description>אחוז מילוי לא 100% (במידה וכן - לשלוח להראות למשתמש - מטופלת מלאה את השאלון)
בחשבון המקושר - אישור דיוור לא &quot;לא מאשר דיוור - הכל&quot;
תאריך הפגישה לא עבר</description>
        <name>Send_The_Survey</name>
        <label>Send The Survey?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Cant_Send_The_Survey_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Send_Survey</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Survey_Taken.Fill_Percentage__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>100.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Survey_Taken.Account__r.Mailing_approval__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>לא מאשר דיוור - הכל</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Survey_Taken.Appointment__r.Appointment_Date_Time__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDateTime</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Survey_Taken.Account__r.SMS_Phone_Number__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_SMS_Data</targetReference>
            </connector>
            <label>Yes- Send Survey</label>
        </rules>
    </decisions>
