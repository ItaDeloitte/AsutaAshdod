    <decisions>
        <name>confirmation_question</name>
        <label>confirmation question?</label>
        <locationX>498</locationX>
        <locationY>502</locationY>
        <defaultConnector>
            <targetReference>update_sms</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>אחר</defaultConnectorLabel>
        <rules>
            <name>confirmation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>loop_sms.question_type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>סקר לאחר תור</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>upd_app</targetReference>
            </connector>
            <label>אישור תור</label>
        </rules>
    </decisions>
    <decisions>
        <name>over</name>
        <label>over?</label>
        <locationX>295</locationX>
        <locationY>491</locationY>
        <defaultConnector>
            <targetReference>for_each_sms</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>טרם</defaultConnectorLabel>
        <rules>
            <name>passed_day</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>today</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>sms_created_date_plus1</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>confirmation_question</targetReference>
            </connector>
            <label>עבר יום מאז נשלחה ההודעה</label>
        </rules>
    </decisions>
    <formulas>
        <name>app_date_minus_1</name>
        <dataType>Date</dataType>
        <expression>{!date_of_appointment} - 1</expression>
    </formulas>
    <formulas>
        <name>sms_created_date_plus1</name>
        <dataType>Date</dataType>
        <expression>{!loop_sms.CreatedDate} + 1</expression>
    </formulas>
    <formulas>
        <name>sms_created_date_plus_2</name>
        <dataType>Date</dataType>
        <expression>{!sms_created_date} + 2</expression>
    </formulas>
    <formulas>
        <name>tizkurit_date_minus_1</name>
        <dataType>Date</dataType>
        <expression>{!loop_sms.Date_of_app_tizkurit__c} - 1</expression>
    </formulas>
    <formulas>
        <name>today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>kill_sms_after_expert {!$Flow.CurrentDateTime}</interviewLabel>
