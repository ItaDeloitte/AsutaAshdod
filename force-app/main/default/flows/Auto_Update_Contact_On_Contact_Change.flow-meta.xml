<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Update_Contact_OTP_Sent_and_Update_SMS_to_Send</name>
        <label>Update Contact / OTP Sent and Update SMS to Send</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>rvContactUpdate.otp_sent__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvContactUpdate.AccountId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvContactTrig.AccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvContactUpdate.Automation_Name__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fAutomationName</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvContactUpdate.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvContactTrig.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvSMS.Account__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvContactTrig.AccountId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvSMS.Automation_name__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fAutomationName</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvSMS.Content__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fContentSMS</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvSMS.Phone_Number__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvContactTrig.SMS_Phone__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvSMS.Type__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Outgoing</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvSMS.status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>1</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_SMS_with_Secret_Code</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Secret_Update_with_SMS_Number</name>
        <label>Secret Update with SMS Number</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No SMS Number</defaultConnectorLabel>
        <rules>
            <name>Contact_Secret_Update</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvContactTrig.Secret__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rvContactTrigPrior.Secret__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvContactTrig.SMS_Phone__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvContactTrig.otp_sent__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Contact_OTP_Sent_and_Update_SMS_to_Send</targetReference>
            </connector>
            <label>Contact Secret Update</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Auto Update Appointment - Contact&apos;+&apos; ||| &apos;+&apos;Triggered By:&apos;+ {!TriggeredByAutomationName}</expression>
    </formulas>
    <formulas>
        <name>fContentSMS</name>
        <dataType>String</dataType>
        <expression>&quot;שלום&quot; &amp; BR() &amp;
&quot;הקוד שלך הוא : &quot; &amp;  {!rvContactTrig.Secret__c}  &amp; BR() &amp;
&quot;תודה, בית החולים אסותא&quot;</expression>
    </formulas>
    <interviewLabel>Auto- Update Contact - On Contact Change {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto- Update Contact - On Contact Change</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_SMS_with_Secret_Code</name>
        <label>Create SMS with Secret Code</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>rvSMS</inputReference>
    </recordCreates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Secret_Update_with_SMS_Number</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>rvContactTrig</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>Contact</objectType>
    </variables>
    <variables>
        <name>rvContactTrigPrior</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>Contact</objectType>
    </variables>
    <variables>
        <name>rvContactUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <objectType>Contact</objectType>
    </variables>
    <variables>
        <name>rvSMS</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>SMS__c</objectType>
    </variables>
    <variables>
        <name>TriggeredByAutomationName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
