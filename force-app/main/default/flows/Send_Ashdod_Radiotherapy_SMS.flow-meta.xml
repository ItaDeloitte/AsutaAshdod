    <decisions>
        <description>בודק האם הפגישה מחר, האם קיים קישור בפעולה הרפואית, האם הפגישה מסוג מכונים ובאתר אשדוד והאם הפגישה היא מחר</description>
        <name>Ashdod_Appointment_Is_Tomorrow_and_Does_Link_Exist_In_Medical_Procedure</name>
        <label>Ashdod Appointment, Is Tomorrow and Does Link Exist In Medical Procedure?</label>
        <locationX>380</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_It_Day_Before_Appointment_And_Does_Link_Exist_in_Medical_Procedure</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Appointment_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>TodayMinus1</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Medical_Procedure__r.Ashdod_Radiotherapy_Link__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Institutes</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Site__r.Site_Code__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>33</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_WhatsApp_Or_SMS</targetReference>
            </connector>
            <label>Is It Day Before Appointment And Does Link Exist in Medical Procedure?</label>
        </rules>
    </decisions>
    <decisions>
        <name>Send_WhatsApp_Or_SMS</name>
        <label>Send WhatsApp Or SMS?</label>
        <locationX>182</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>Assign_SMS</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Send_WA</name>
            <conditionLogic>(1 AND 2) OR (1 AND 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Patient_Account__r.Number_not_Kosher__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Patient_Account__r.AshdodPreferredChannel__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>WA</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Patient_Account__r.AshdodPreferredChannel__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_WA</targetReference>
            </connector>
            <label>Send WA</label>
        </rules>
    </decisions>
    <description>פלואו מתוזמן שרץ כל יום ב8 בבוקר ושולח סמס לפגישות שפעולה הרפואית שלהם &apos;P980522&apos; יום לפני הפגישה עם קישור לסרטון הכנה לפגישה
