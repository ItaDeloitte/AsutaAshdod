    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Auto Update Account On Account Change&apos;+&apos; ||| &apos;+&apos;Triggered By:&apos;+ {!TriggeredByAutomationName}</expression>
    </formulas>
    <formulas>
        <name>fPassportNumList</name>
        <dataType>String</dataType>
        <expression>IF(
ISBLANK({!rvAccountTrig.PassportNumList__c}),
{!rvAccountPrior.ID_Number__c},
{!rvAccountTrig.PassportNumList__c} &amp; &apos;,&apos; &amp; {!rvAccountPrior.ID_Number__c}
)</expression>
    </formulas>
    <formulas>
        <name>fSatisfaction</name>
        <dataType>Number</dataType>
        <expression>IF(
{!rvAccountTrig.Survey_Avg__c} + 
IF(  ISBLANK( {!rvAccountTrig.satisfaction__c}),  {!rvAccountTrig.grade_sum__c}, {!rvAccountTrig.satisfaction__c})  /2 &gt; 99,
99.99,
{!rvAccountTrig.Survey_Avg__c} + 
IF(  ISBLANK( {!rvAccountTrig.satisfaction__c}),  {!rvAccountTrig.grade_sum__c}, {!rvAccountTrig.satisfaction__c})  /2
)</expression>
        <scale>2</scale>
    </formulas>
