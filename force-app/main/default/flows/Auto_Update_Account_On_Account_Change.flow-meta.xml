    <decisions>
        <description>Workflow Rule : האם קיבל סקר?</description>
        <name>Did_Patient_Received_a_Survey</name>
        <label>Did Patient Received a Survey?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Is_OTP_Email_hidden_different_than_Person_Email</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Patient_Received_a_Survey</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvAccountTrig.grade_sum__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>rvAccountPrior.grade_sum__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvAccountTrig.grade_sum__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Satisfaction</targetReference>
            </connector>
            <label>Patient Received a Survey</label>
        </rules>
    </decisions>
