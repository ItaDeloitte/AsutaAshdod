        <description>רופא באתר</description>
        <name>Get_Doctor_In_Site</name>
        <label>Get Doctor In Site</label>
        <locationX>264</locationX>
        <locationY>468</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_Email_Message_Data</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Main_Site__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Account__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Loop_Survey_Taken.Doctor__r.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Doctor_in_site__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Survey_Taken</name>
        <label>Get Survey Taken</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Survey_Taken</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SurveyCode__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>DocSatisfaction</stringValue>
            </value>
        </filters>
        <filters>
            <field>is_sms_sent__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Fill_Percentage__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>100.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>IsReminderSent__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>SurveyReminderDatetime__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>fSMSSendTimeMin</elementReference>
            </value>
        </filters>
        <filters>
            <field>SurveyReminderDatetime__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>fSMSSendTimeMax</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>SurveyTaker__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
