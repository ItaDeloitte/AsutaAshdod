    <description>AM: 12052025- 1978142113- סקר לרופא הנקלט - התעלמות של הרופא מהסקר גם לאחר תזכורת</description>
    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Scheduled_Doctor_Satisfaction_Survey_Ignored &apos; + TEXT(NOW())</expression>
    </formulas>
    <formulas>
        <name>fSMSSendTimeMax</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE(TEXT(TODAY() -7)+&apos; 23:59:59&apos;)</expression>
    </formulas>
    <formulas>
        <name>fSMSSendTimeMin</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE(TEXT(TODAY() -7)+&apos; 00:00:00&apos;)</expression>
    </formulas>
    <formulas>
        <name>fSurveyIgnoredMessage</name>
        <dataType>String</dataType>
        <expression>&quot;שלום רב,\n&quot; &amp;
&quot;לתשומת לבך, &quot; &amp; {!Loop_Survey_Taken.Doctor__r.RoleDescription__c} &amp; &quot; &quot; &amp; {!Loop_Survey_Taken.Doctor__r.Name} &amp; &quot; טרם השלים את מילוי סקר שביעות הרצון בנושא תהליך הקליטה שנשלח לפני חודשיים בקירוב.\n&quot; &amp;
&quot;נודה ליצירת קשר עם &quot; &amp; {!Loop_Survey_Taken.Doctor__r.Name} &amp; &quot; לטובת תזכורת למילוי הסקר החשוב.\n\n&quot; &amp;
&quot;בתודה מראש\n&quot; &amp;
&quot;אגף הרפואה&quot;</expression>
    </formulas>
    <formulas>
        <name>fToAddress</name>
        <dataType>String</dataType>
        <expression>{!Get_Doctor_In_Site.Site__r.Medical_Manager_Email__c}+&apos;,&apos;+{!Get_Doctor_In_Site.Site__r.Doc_Coordinator_Manager__c}+&apos;,&apos;+{!Get_Doctor_In_Site.Site__r.Doc_Coordinator_HQ__c}</expression>
    </formulas>
    <interviewLabel>Scheduled- Doctor Satisfaction Survey Ignored {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Scheduled- Doctor Satisfaction Survey Ignored</label>
