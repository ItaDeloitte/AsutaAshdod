            </connector>
            <label>SMS Channel</label>
        </rules>
        <rules>
            <name>Email_Channel</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>PreferredChannel</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
