                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Email_Template_Id</targetReference>
            </connector>
            <label>Email Channel</label>
        </rules>
    </decisions>
    <description>AM: 2117312470- 09092025- this flow originates from &quot;Send Digital Document&quot; flow. it is designed for ashdod users
AM: 12112025- bug fix- added expected sending time for sms cgannel</description>
    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Send Digital Document- Ashdod&apos;+&apos; &apos;+{!$User.Email}</expression>
    </formulas>
    <formulas>
        <name>fFileUploadSMSText</name>
        <dataType>String</dataType>
        <expression>&quot;שלום, &quot;&amp;BR()  
&amp;&quot;לבקשתך, מצורף קישור להעלאת מסמכים.&quot;
&amp;BR()  
&amp;&quot;אנא כנס לקישור וצרף את המסמך הרלוונטי:&quot;
&amp;&quot; &quot;&amp; {!Get_Case.digital_Upload_files_url__c}
&amp;BR() &amp;BR()  
&amp;&quot;בברכה, &quot;
&amp;&quot;בית החולים הציבורי אסותא אשדוד&quot;</expression>
    </formulas>
    <formulas>
        <name>fNOW</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
