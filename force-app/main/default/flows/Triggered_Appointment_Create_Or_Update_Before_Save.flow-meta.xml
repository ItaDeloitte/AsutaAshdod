    <decisions>
        <name>Check_If_Doctor_Is_Allowed_For_Med_Procedure</name>
        <label>New Appointment Or Changed Doctor Or Medical Procedure</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Check_If_Doctor_Allowed_For_Medical_Procedure</name>
            <conditionLogic>1 AND (2 OR 3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Surgeries</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fISNEW</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Doctor_Account__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Medical_Procedure__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Doctor_Medical_Procedure</targetReference>
            </connector>
            <label>Yes- Check If Doctor Allowed For Medical Procedure</label>
        </rules>
    </decisions>
    <decisions>
        <description>if The medical procedure does not exists for that doctor - it is not alowed to do the medical procedure.</description>
        <name>Found_Doctor_Medical_Procedure</name>
        <label>Found Doctor Medical Procedure?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Copy_1_of_Assign_Appointment_Data_Doc_Not_Allowed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No_Doctor_Is_Not_Allowed_For_Medical_Procedure</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Doctor_Medical_Procedure</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Appointment_Data_Doc_Not_Allowed</targetReference>
            </connector>
            <label>No- Doctor Is Not Allowed For Medical Procedure</label>
        </rules>
    </decisions>
