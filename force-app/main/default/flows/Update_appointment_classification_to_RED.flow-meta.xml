<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Check if the combination of medical procedure and doctor is house doctor (red classification)</description>
        <name>Is_it_a_house_doctor</name>
        <label>Is it a house doctor?</label>
        <locationX>592</locationX>
        <locationY>52</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>House_Doctor_TRUE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>HouseDoctor</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_appointment_to_RED</targetReference>
            </connector>
            <label>House Doctor TRUE</label>
        </rules>
        <rules>
            <name>House_Doctor_FALSE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>HouseDoctor</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>House Doctor FALSE</label>
        </rules>
    </decisions>
    <description>When new appointment RT = surgeries, check if it&apos;s a Red classification, and update</description>
    <interviewLabel>Update appointment classification to RED {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update appointment classification to RED</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get the junction record for the Doctor and the Medical procedure of the surgery</description>
        <name>Get_Doctor_Medical_Procedure_Record</name>
        <label>Get Doctor Medical Procedure Record</label>
        <locationX>390</locationX>
        <locationY>50</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Is_it_a_house_doctor</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Doctor__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>DoctorID</elementReference>
            </value>
        </filters>
        <filters>
            <field>Medical_Procedure__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>MedicalProcedureID</elementReference>
            </value>
        </filters>
        <object>Doctor_Medical_Procedure__c</object>
        <outputAssignments>
            <assignToReference>HouseDoctor</assignToReference>
            <field>House_doctor__c</field>
        </outputAssignments>
    </recordLookups>
    <recordUpdates>
        <name>Update_appointment_to_RED</name>
        <label>Update appointment to RED</label>
        <locationX>904</locationX>
        <locationY>51</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>AppointmentID</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Classification__c</field>
            <value>
                <stringValue>אדום</stringValue>
            </value>
        </inputAssignments>
        <object>Appointment__c</object>
    </recordUpdates>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Get_Doctor_Medical_Procedure_Record</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>AppointmentID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>DoctorID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>HouseDoctor</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>MedicalProcedureID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
</Flow>
