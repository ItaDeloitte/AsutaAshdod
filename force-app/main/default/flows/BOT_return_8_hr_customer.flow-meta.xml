<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>found_session_less_8_hr</name>
        <label>found session less 8 hr</label>
        <locationX>660</locationX>
        <locationY>369</locationY>
        <assignmentItems>
            <assignToReference>customer_less_then_8hr</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>YES</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Last_Agent</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Messaging_Session_by_end_user_id.OwnerId</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Is_last_customer_session_less_then_8_hr</name>
        <label>Is last customer session less then 8 hr?</label>
        <locationX>372</locationX>
        <locationY>369</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Last_session_time</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>8.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Messaging_Session_by_end_user_id.CreatedDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>get_account.Last_Agent__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>found_session_less_8_hr</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>Added a ned condition to get messaging Session,
condution:  does not equal to Assuta_Ashdod_Bot</description>
    <environments>Default</environments>
    <formulas>
        <name>Last_session_time</name>
        <dataType>Number</dataType>
        <expression>(NOW() - {!Get_Messaging_Session_by_end_user_id.CreatedDate})*24</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>BOT return 8 hr customer {!$Flow.CurrentDateTime}</interviewLabel>
    <label>BOT return 8 hr customer</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>get_account</name>
        <label>get account</label>
        <locationX>176</locationX>
        <locationY>191</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Messaging_Session_by_end_user_id</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ID_Number__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Patient_ID</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Messaging_Session_by_end_user_id</name>
        <label>Get Messaging Session by end user id</label>
        <locationX>175</locationX>
        <locationY>370</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Is_last_customer_session_less_then_8_hr</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>New_Account__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>get_account.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Bot_Queue__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>shikum_bait</stringValue>
            </value>
        </filters>
        <filters>
            <field>MessagingChannelId</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Label.Ashdod_Digital_Engagment_Channel_WA</elementReference>
            </value>
        </filters>
        <filters>
            <field>MessagingChannelId</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Label.Ashdod_Digital_Engagment_Channel_Chat</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>MessagingSession</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>get_account</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>customer_less_then_8hr</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <value>
            <stringValue>NO</stringValue>
        </value>
    </variables>
    <variables>
        <name>Last_Agent</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>Patient_ID</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
