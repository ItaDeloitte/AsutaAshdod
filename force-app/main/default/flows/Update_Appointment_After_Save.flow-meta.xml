    <formulas>
        <description>WorkFlow - Update app name to medical precedure</description>
        <name>AppointmentName</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!$Record.Date_of_appointment__c})),
{!$Record.Medical_Procedure__r.Marketing_Procedure_Name__c} +&quot; &quot;+ TEXT(DAY({!$Record.Date_of_appointment__c})) +&quot;/&quot;+ TEXT( MONTH({!$Record.Date_of_appointment__c})) +&quot;/&quot;+ TEXT(YEAR({!$Record.Date_of_appointment__c})),
LEFT({!$Record.Medical_Procedure__r.Marketing_Procedure_Name__c} , 69))</expression>
    </formulas>
    <formulas>
        <description>WorkFlow - Update name of experts appointment</description>
        <name>AppointmentNameExperts</name>
        <dataType>String</dataType>
        <expression>IF( NOT(ISBLANK({!$Record.Doctor_Account__c})), 
{!$Record.Doctor_Account__r.Name} , 
{!$Record.Calendar__r.Doc_Name__c}) +&quot; &quot;+
LPAD(TEXT(DAY({!$Record.Date_of_appointment__c})),2,&quot;0&quot;)+&quot;/&quot;+LPAD(TEXT(MONTH({!$Record.Date_of_appointment__c})),2,&quot;0&quot;)+&quot;/&quot;+
TEXT(YEAR({!$Record.Date_of_appointment__c}))</expression>
    </formulas>
    <formulas>
        <description>WorkFlow -Update Surgery Name not Marketing</description>
        <name>AppointmentNameNotMarketing</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!$Record.Date_of_appointment__c})),
{!$Record.Medical_Procedure__r.Name}+&quot; &quot;+TEXT(DAY({!$Record.Date_of_appointment__c}))+&quot;/&quot;+TEXT( MONTH({!$Record.Date_of_appointment__c}))+&quot;/&quot;+TEXT(YEAR({!$Record.Date_of_appointment__c})),
 LEFT({!$Record.Medical_Procedure__r.Name}, 69)  )</expression>
    </formulas>
    <formulas>
        <name>FinalCostSum</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Final_Cost_of_Med_1__c}+{!$Record.Final_Cost_of_Med_2__c}+{!$Record.Final_Cost_of_Med_3__c}+{!$Record.Final_Cost_of_Med_4__c}</expression>
        <scale>2</scale>
    </formulas>
