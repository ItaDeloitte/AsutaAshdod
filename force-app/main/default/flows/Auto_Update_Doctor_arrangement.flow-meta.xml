    <decisions>
        <name>If_Is_New_Or_Arrangement_c_or_Doctor_c_Is_Change</name>
        <label>If Is New Or Arrangement__c or Doctor__c Is Change</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Is_Doector_Expert</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_The_Record_Is_New_Or_Change</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Doctor_arrangementPrior.Doctor__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Doctor_arrangementTrig.Doctor__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Doctor_arrangementPrior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Name</targetReference>
            </connector>
            <label>Yes The Record Is New Or Change</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Doector_Expert</name>
        <label>Is Doector  Expert ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Doctor_Account</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_The_Doctor_Is_Expert</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Doctor_arrangementTrig.Arrangment_Name__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>מומחיםי&apos;</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Doctor_arrangementTrig.Doctor__r.Experts_center__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Account_Experts_Center</targetReference>
            </connector>
            <label>Yes The Doctor Is Expert</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
