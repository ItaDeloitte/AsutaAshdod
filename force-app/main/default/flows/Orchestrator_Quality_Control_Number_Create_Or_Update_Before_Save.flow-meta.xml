    <decisions>
        <description>Workflows Rules to Flow : 
בקרת איכות אדומה
בקרת איכות ירוקה
בקרת איכות כתוםה</description>
        <name>Check_SLA_Values</name>
        <label>Check SLA Values</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SLA_Green</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>tvSLAChosen</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ירוק</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Date_target__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>fCreatedDatePlus10</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_QA_Target_Closure_Date_to_CreatedDate_10</targetReference>
            </connector>
            <label>SLA Green</label>
        </rules>
        <rules>
            <name>SLA_Orange</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>tvSLAChosen</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>כתום</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Date_target__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>fCreatedDatePlus3</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_QA_Target_Closure_Date_to_CreatedDate_3</targetReference>
            </connector>
            <label>SLA Orange</label>
        </rules>
        <rules>
            <name>SLA_Red</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>tvSLAChosen</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>אדום</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Date_target__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>fCreatedDatePlus1</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_QA_Target_Closure_Date_to_CreatedDate_1</targetReference>
            </connector>
            <label>SLA Red</label>
        </rules>
    </decisions>
    <decisions>
        <description>From Workflow Rules : מקור הפנייה - מוקד and מקור הפנייה - מכון</description>
        <name>Is_Isnew_or_Ischanged_Created_By_User</name>
        <label>Is Isnew or Ischanged(Created By User) ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Is_QA_Source</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>For_Institute</name>
            <conditionLogic>(1 OR 2) AND ( 3 OR 4 ) AND 5</conditionLogic>
            <conditions>
                <leftValueReference>ISNEW</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Secretary</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Partner Community User Custom</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.QC_Source__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>פניה מהמכון</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_QA_Source_to_Institute</targetReference>
            </connector>
            <label>For Institute</label>
        </rules>
        <rules>
            <name>For_Call_Center</name>
            <conditionLogic>(1 OR 2 ) AND (3 OR 4 OR 5 OR 6 OR 7 OR 8) AND 9</conditionLogic>
            <conditions>
                <leftValueReference>ISNEW</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New System Admin</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>משתמש סטנדרטי - חדש</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>מנהל</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Service user DEV</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Call_Center_Coordinator</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Created_by_User__r.Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Call_Center_Senior_Coordinator</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.QC_Source__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>פניה מהמוקד</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>et_QA_Source_to_Call_Center</targetReference>
            </connector>
            <label>For Call Center</label>
        </rules>
    </decisions>
    <decisions>
        <description>From Workflow Rules : מילוי מנהל
needed t o replace the formula field &quot;Managed?&quot;(not compatible with Before Update) by the formula itself	 

IF( NOT(ISblank( Related_User__c ))&amp;&amp;ISblank(Related_User__r.ManagerId) , TRUE, FALSE)

as the related agent is always not null (condition 1 below),
 to get the result required False, the ManagerId has to be Not Blank</description>
        <name>Is_Manager_Filling_Required</name>
        <label>Is Manager Filling Required?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_SLA_Values</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Manager_Filling_Required</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Related_User__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.manager_transfered__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Related_User__r.ManagerId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_QA_Source_to_Manager_Filling</targetReference>
            </connector>
            <label>Manager Filling Required</label>
        </rules>
    </decisions>
