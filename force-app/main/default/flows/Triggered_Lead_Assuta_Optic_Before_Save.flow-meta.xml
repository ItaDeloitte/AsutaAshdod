        <locationX>270</locationX>
        <locationY>611</locationY>
        <defaultConnector>
            <targetReference>Loop_Get_Leads_By_Conditions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Lead_In_Campaign</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Get_Leads_By_Conditions.Campaign__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>אסותא אופטיק - עמוד נחיתה חיצוני</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Get_Leads_By_Conditions.Campaign__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>אסותא אופטיק קולבוקס</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Get_Leads_By_Conditions.Campaign__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>אסותא אופטיק - טופס אתר הבית</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Get_Leads_By_Conditions.Campaign__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>אסותא אופטיק</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Lead_Duplication_Indication</targetReference>
            </connector>
            <label>Yes- Lead In Campaign</label>
        </rules>
    </decisions>
