<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Status_and_DateTime</name>
        <label>Assign Status and DateTime</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Status_private_room__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Canceled</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Cancellation_Date_Time_Private_Rooms__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fNOW</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Is_payment_valid</name>
        <label>Is payment valid</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_valid</name>
            <conditionLogic>1 AND 2 AND (3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PaymentStatus__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Valid</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Cancellation_Date_Time_Private_Rooms__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status_private_room__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>שוריין חדר</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status_private_room__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>paid</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Status_and_DateTime</targetReference>
            </connector>
            <label>Yes - valid</label>
        </rules>
    </decisions>
    <description>Refactor version v1</description>
    <environments>Default</environments>
    <formulas>
        <name>fNOW</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
    <interviewLabel>Canceled Surgeries Appiontment {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Canceled Surgeries Appiontment</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_payment_valid</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &apos;Surgeries&apos; &amp;&amp; 
(
    TEXT({!$Record.Appointment_Status__c}) = &apos;Canceled&apos; || 
    TEXT({!$Record.Appointment_Status__c}) = &apos;2&apos;
)</filterFormula>
        <object>Appointment__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>rvAppointment</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Appointment__c</objectType>
    </variables>
</Flow>
