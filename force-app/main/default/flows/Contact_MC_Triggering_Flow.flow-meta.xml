<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Opt_Out_Timestamp</name>
        <label>Assign Opt Out Timestamp</label>
        <locationX>50</locationX>
        <locationY>731</locationY>
        <assignmentItems>
            <assignToReference>$Record.Opt_Out_Time_Stamp__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>now</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Account_Mailing_Approval_If_Different</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_TS_Sync_To_MC_Now</name>
        <label>Assign TS Sync To MC-- Now</label>
        <locationX>138</locationX>
        <locationY>431</locationY>
        <assignmentItems>
            <assignToReference>$Record.TS_Sync_To_MC__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>now</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Marketing_Cloud_Triggers</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>קיימים 4 תרחישים להטרגת תהליך הסנכרון של ליד ל MC
1. ליד קיים- בו משתנה הדיוור
2. ליד חדש
3. ליד אשר משתנה בו הערך בצקבוס synctomc
4. ליד שהומר</description>
        <name>Marketing_Cloud_Triggers</name>
        <label>Marketing Cloud Triggers</label>
        <locationX>270</locationX>
        <locationY>623</locationY>
        <defaultConnector>
            <targetReference>Update_Triggering_Contact2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Mailing_Approval_Changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Mailing_approval__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Opt_Out_Timestamp</targetReference>
            </connector>
            <label>Mailing Approval Changed</label>
        </rules>
        <rules>
            <name>Contact_Is_New</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Mailing_Approval_If_Different</targetReference>
            </connector>
            <label>Contact Is New</label>
        </rules>
    </decisions>
    <decisions>
        <name>SyncToMC_Changed</name>
        <label>SyncToMC Changed</label>
        <locationX>270</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Marketing_Cloud_Triggers</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SyncToMC_Changed1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SyncToMC__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_TS_Sync_To_MC_Now</targetReference>
            </connector>
            <label>SyncToMC Changed</label>
        </rules>
    </decisions>
    <description>אוטומציה שפועלת על ה MC</description>
    <environments>Default</environments>
    <formulas>
        <name>Leadtext</name>
        <dataType>String</dataType>
        <expression>{!$Record.Email}</expression>
    </formulas>
    <formulas>
        <name>now</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
    <interviewLabel>Contact MC Triggering Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Contact MC Triggering Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>If the mailing approval of the related account is different than that of the triggering contact, it will be updated to the new value of the contact mailing approval.</description>
        <name>Update_Account_Mailing_Approval_If_Different</name>
        <label>Update Account Mailing Approval If Different</label>
        <locationX>270</locationX>
        <locationY>1031</locationY>
        <connector>
            <targetReference>Update_Triggering_Contact</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>IsPersonAccount</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Mailing_approval__c</field>
            <value>
                <elementReference>$Record.Mailing_approval__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>PhoneToMC__pc</field>
            <value>
                <elementReference>$Record.PhoneToMC_Helper__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record.Account</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Triggering_Contact</name>
        <label>Update Triggering Contact</label>
        <locationX>270</locationX>
        <locationY>1139</locationY>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Triggering_Contact2</name>
        <label>Update Triggering Contact</label>
        <locationX>490</locationX>
        <locationY>731</locationY>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>144</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>SyncToMC_Changed</targetReference>
        </connector>
        <filterFormula>ISCHANGED({!$Record.Mailing_approval__c}) || ISNEW() || ISCHANGED({!$Record.SyncToMC__c})</filterFormula>
        <object>Contact</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
