        <name>fourDaysBeforeDatePassed</name>
        <label>תאריך כבר עבר?</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Set_Four_Days_Due_Date</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Date_Passed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Four_days_before_4Videos.Due_Date</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>Today</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Four_Days_Before_To_Today</targetReference>
            </connector>
            <label>תאריך עבר- 4 ימים לפני</label>
        </rules>
    </decisions>
    <description>שולח סמס תזכורת להעלת התחייבות 4 ימי עסקים לפני ניתוח- רלוונטי לפגישות מסוג ניתוח, שערך השדה &quot;התקבלה התחייבות באמצעות טופס דיגיטלי&quot; הוא false, שסטטוס הפגישה היא טיפול אדמנסטרטיבי או ממתין להתחייבות, ושגורם המשלם הוא חברת ביטוח או קוד הלקוח אב הוא 4 או 5</description>
    <environments>Default</environments>
    <formulas>
