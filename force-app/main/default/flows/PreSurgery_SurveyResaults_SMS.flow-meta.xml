    <decisions>
        <description>when SurveyResults__c field is populated direct to the appropriate SMS template</description>
        <name>Survey_Results</name>
        <label>Survey Results</label>
        <locationX>531</locationX>
        <locationY>471</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Required_PreSurgery_Assesment</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SurveyResults__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>נדרשת הערכה במרפאת טרום ניתוח</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AssesmentRequired</targetReference>
            </connector>
            <label>Required PreSurgery Assesment</label>
        </rules>
        <rules>
            <name>Not_Required_PreSurgery_Assesment</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SurveyResults__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>לא נדרש טרום ניתוח</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assesment_Not_Required</targetReference>
            </connector>
            <label>Not Required PreSurgery Assesment</label>
        </rules>
        <rules>
            <name>SurveyResultNurse</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SurveyResults__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>לבדיקת אחות טרום ניתוח – החלטה והמלצות</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Nurse_Assesmet</targetReference>
            </connector>
            <label>SurveyResultNurse</label>
        </rules>
        <rules>
            <name>Nurse_Assessment</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.NurseStatus__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>נדרש לזמן טרום במרפאה</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Nurse_Recommendation_for_Assesmet0</targetReference>
            </connector>
            <label>Nurse Assessment Required</label>
        </rules>
        <rules>
            <name>Nurse_Not_Required</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.NurseStatus__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>לא נדרש טרום לפני הניתוח</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Nurse_No_Assesment</targetReference>
            </connector>
            <label>Nurse Not Required</label>
        </rules>
        <rules>
            <name>Nurse_Remote</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.NurseStatus__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>הערכה מרחוק</stringValue>
                </rightValue>
            </conditions>
            <label>Nurse Remote</label>
        </rules>
    </decisions>
