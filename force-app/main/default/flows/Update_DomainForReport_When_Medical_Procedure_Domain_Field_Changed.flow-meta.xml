<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>ExpertCenter</name>
        <label>מרכז מומחים?</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>ExpertCenterDomain</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>NotExpertCenterDomain</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Domain__r.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>מרכז מומחים</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_DomainForReport</targetReference>
            </connector>
            <label>התחום לא שייך למרכז מומחים</label>
        </rules>
    </decisions>
    <description>כאשר נעשה שינוי בשדה domain__c באובייקט פעולה רפואית, יעודכן ערכו של השדה DomainForReport__c
אם התחום בפעולה הרפואית היא לא של מרכז מומחים, ערך השדה DomainForReport__c ישויך עם ערך התחום מהשדה domain__c
אחרת, השדה יישאר ריק</description>
    <environments>Default</environments>
    <interviewLabel>Update DomainForReport When Medical Procedure Domain Field Changed {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update DomainForReport When Medical Procedure Domain Field Changed</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>ExpertCenterDomain</name>
        <label>Domain מרכז מומחים</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <inputAssignments>
            <field>DomainForReport__c</field>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_DomainForReport</name>
        <label>Update DomainForReport</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <inputAssignments>
            <field>DomainForReport__c</field>
            <value>
                <elementReference>$Record.Domain__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>ExpertCenter</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Domain__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Medical_Procedure__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
