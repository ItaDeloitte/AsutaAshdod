        <connector>
            <targetReference>Get_main_site</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>פעיל</stringValue>
            </value>
        </filters>
        <filters>
            <field>doctor_id__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Doc_Id_Text</elementReference>
            </value>
        </filters>
        <object>Doctor_in_site__c</object>
