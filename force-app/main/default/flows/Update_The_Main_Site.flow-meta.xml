        <connector>
            <targetReference>Removing_Tick</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>doctor_id__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Doc_Id_Text</elementReference>
            </value>
        </filters>
        <filters>
            <field>Main_Site__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Doctor_in_site__c</object>
        <outputReference>Sites</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
