<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>the origin is : Email Alert - Disabilities to site  (i have converted it to email message)</description>
        <name>Assign_Enail_Message_Data</name>
        <label>Assign Enail Message Data</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>rvEmailMessage.AccountId__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvAppointmentTrig.Patient_Account__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.AppointmentId__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvAppointmentTrig.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.EmailTemplateDeveloperName__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Disabilities</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.ToAddress</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvAppointmentTrig.Site_Email__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.FromName</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Assuta No-Reply</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.FromAddress</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>nonreply@assuta.co.il</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.ExpectedSendingDateTime__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.Automation_name__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fAutomationName</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.Subject</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue> עזרים נדרשים למטופל</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.EmailTemplateId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_EmailTemplateId.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.RelatedToId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvAppointmentTrig.Patient_Account__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessage.TemplateMergeField__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>AppointmentId__c</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_Email_Message</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Check_If_Disability_Exists</name>
        <label>Check If Disability Exists?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Check_If_Disability_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvAppointmentTrig.Appointment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>WaitingForAppointment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvAppointmentTrig.Site_Email__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Disabilitie_For_Patient</targetReference>
            </connector>
            <label>Yes- Check If Disability Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Found_Disability_For_Patient</name>
        <label>Found Disability For Patient?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Disability_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Disabilitie_For_Patient</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_EmailTemplateId</targetReference>
            </connector>
            <label>Yes- Disability Exists</label>
        </rules>
    </decisions>
    <description>AM: 05042026- 2822289047- pb to flow conversion- also create &quot;Send_Disability_to_Site&quot; from scratch by new conventions + as 
       emailmessage. (יבדוק אם למטופל יש מוגבלויות פעילות ובמידה וכן ישלח מייל לאתר)</description>
    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Auto- Send Disability To Site &apos;+&apos; ||| &apos;+&apos; Triggered By: &apos;+{!tvAutomationName}</expression>
    </formulas>
    <interviewLabel>Auto- Send Disability To Site {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto- Send Disability To Site</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Email_Message</name>
        <label>Create Email Message</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>rvEmailMessage</inputReference>
    </recordCreates>
    <recordLookups>
        <name>Get_Disabilitie_For_Patient</name>
        <label>Get Disabilitie For Patient</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Found_Disability_For_Patient</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Patient_Account__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>rvAppointmentTrig.Patient_Account__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status_Disability__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>פעיל</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Disabilities__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_EmailTemplateId</name>
        <label>Get EmailTemplateId</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_Enail_Message_Data</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Disabilities</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>EmailTemplate</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_If_Disability_Exists</targetReference>
        </connector>
    </start>
