    <assignments>
        <name>Assign_Recepients</name>
        <label>Assign Recepients</label>
        <locationX>417</locationX>
        <locationY>411</locationY>
        <assignmentItems>
            <assignToReference>NotificationRecepients</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>$Record.Parent.OwnerId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Case_Record_type_and_case</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>הקייס במצב בטיפול/ סגור וגם סוג הפנייה שייך לפניות הציבור ?</description>
        <name>Case_Record_type_and_case</name>
        <label>Case Record type and case Match</label>
        <locationX>593</locationX>
        <locationY>411</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>True</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Following</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PublicInquiries</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Custom_Notification</targetReference>
            </connector>
            <label>True</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_the_case_related_to_Merkazim_or_to_Ashdod</name>
        <label>האם הפניה היא של מרכזים או של אשדוד</label>
        <locationX>1247</locationX>
        <locationY>410</locationY>
        <defaultConnector>
            <targetReference>Update_Case_Status_to_In_Progress</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>הפניה שייכת לאשדוד</defaultConnectorLabel>
        <rules>
            <name>The_case_is_related_to_Merkazim</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Site.Site_Code__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>33</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_the_Status_Closed_or_Following</targetReference>
            </connector>
            <label>הפניה שייכת למרכזים</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_the_Status_Closed_or_Following</name>
        <label>האם סטטוס הפניה הוא סגור או במעקב</label>
        <locationX>1247</locationX>
        <locationY>678</locationY>
        <defaultConnectorLabel>הסטטוס במעקב</defaultConnectorLabel>
        <rules>
            <name>The_Status_is_Closed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_parent_case.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_the_Csae_Status_to_New</targetReference>
            </connector>
            <label>הסטטוס סגור</label>
        </rules>
    </decisions>
    <description>מייצר התראה ברגע שעונים למייל בפניה מסוג פניות הציבור, ומשנה את הסטטוס של הפניה במידת הצורך</description>
    <environments>Default</environments>
    <formulas>
        <description>Variable to show Notification Title and Body</description>
        <name>NotificationBody</name>
        <dataType>String</dataType>
        <expression>&apos;שים לב לפנייה מספר&apos;+&apos; &apos;+{!$Record.Parent.CaseNumber}+&apos; &apos;+&apos;התקבל מייל הדורש את התייחסותך&apos;</expression>
    </formulas>
    <interviewLabel>Custom Notifications From Email {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Custom Notifications From Email</label>
    <processMetadataValues>
