    <recordCreates>
        <name>Create_SMS</name>
        <label>Create SMS</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Assign_Update_SMS_Sent_Checkbox</targetReference>
        </connector>
        <inputReference>rvSMS</inputReference>
    </recordCreates>
    <recordLookups>
        <name>Get_Department_Transfers_SMS_Template</name>
        <label>Get Department Transfers SMS Template</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>General_Information_Department_Transfer</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>transfer_to_secretaries</stringValue>
            </value>
        </filters>
        <filters>
            <field>ObjectName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Case__c</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>SmsTemplate__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Existing_Assuta_Files</name>
        <label>Get Existing Assuta Files</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Coun</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Case__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <object>File__c</object>
        <outputReference>getAssutaFiles1</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
    </recordLookups>
    <recordUpdates>
        <name>Update_Triggering_Case</name>
        <label>Update Triggering Case</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>rvCase</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Ashdod_Site</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName}= &apos;transfer_to_secretaries&apos;	
|| {!$Record.RecordType.DeveloperName}= &apos;General_Info&apos;
|| {!$Record.RecordType.DeveloperName}= &apos;PublicInquiries&apos;</filterFormula>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
