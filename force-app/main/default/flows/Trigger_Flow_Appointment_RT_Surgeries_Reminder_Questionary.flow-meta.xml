    <formulas>
        <name>For10DaysReminderDate</name>
        <dataType>Date</dataType>
        <expression>IF  (  WEEKDAY( {!$Record.Appointment_Date__c}-10)  &lt;= 5, 
        {!$Record.Appointment_Date__c}-10 ,
      IF(  WEEKDAY({!$Record.Appointment_Date__c}-10)  = 6 ,
        {!$Record.Appointment_Date__c} -11,
        {!$Record.Appointment_Date__c} -9)
    )</expression>
    </formulas>
    <formulas>
        <name>For20DaysReminderDate</name>
        <dataType>Date</dataType>
        <expression>IF  (  WEEKDAY( {!$Record.Appointment_Date__c}-20)  &lt;= 5, 
        {!$Record.Appointment_Date__c}-20 ,
      IF(  WEEKDAY({!$Record.Appointment_Date__c}-20)  = 6 ,
        {!$Record.Appointment_Date__c} -21,
        {!$Record.Appointment_Date__c} -19)
    )</expression>
    </formulas>
    <formulas>
        <name>For30DaysReminderDate</name>
        <dataType>Date</dataType>
        <expression>IF  (  WEEKDAY( {!$Record.Appointment_Date__c}-30)  &lt;= 5, 
        {!$Record.Appointment_Date__c}-30 ,
      IF(  WEEKDAY({!$Record.Appointment_Date__c}-30)  = 6 ,
        {!$Record.Appointment_Date__c} -31,
        {!$Record.Appointment_Date__c} -29)
    )</expression>
    </formulas>
