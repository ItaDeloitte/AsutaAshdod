<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Lead_Duplication_Indication</name>
        <label>Assign Lead Duplication Indication</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Contacted_Previously__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Assign_Lead_Duplication_Indication_False</name>
        <label>Assign Lead Duplication Indication- False</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Contacted_Previously__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Lead_Records_By_Conditions</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Found_Other_Leads</name>
        <label>Found Other Leads?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Previous_Lead_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Lead_Records_By_Conditions</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Get_Leads_By_Conditions</targetReference>
            </connector>
            <label>Yes - Previous Lead Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Phone_Changed</name>
        <label>Is Phone Changed?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_Lead_Records_By_Conditions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Phone_Changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Phone</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Campaign__r.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Family</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Lead_Duplication_Indication_False</targetReference>
            </connector>
            <label>Yes- Phone Changed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Lead_in_Campaign</name>
        <label>Lead in Campaign?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Get_Leads_By_Conditions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Lead_in_Campaign</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Get_Leads_By_Conditions.Campaign__r.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Family</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Lead_Duplication_Indication</targetReference>
            </connector>
            <label>Yes - Lead in Campaign</label>
        </rules>
    </decisions>
    <description>NC: 21122025- 2514907331 ביצוע התאמות לאסותא פמילי בסביבת מכירות</description>
    <environments>Default</environments>
    <interviewLabel>Triggered- Lead- Assuta Family- Before Save {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Triggered- Lead- Assuta Family- Before Save</label>
    <loops>
        <name>Loop_Get_Leads_By_Conditions</name>
        <label>Loop Get Leads By Conditions</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Lead_Records_By_Conditions</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Lead_in_Campaign</targetReference>
        </nextValueConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Lead_Records_By_Conditions</name>
        <label>Get Lead Records By Conditions</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Found_Other_Leads</targetReference>
        </connector>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>Id</field>
            <operator>NotEqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Phone</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Phone</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Lead</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Phone_Changed</targetReference>
        </connector>
        <filterFormula> OR(
        ISNEW(),CONTAINS(UPPER({!$Record.Campaign__r.Name}),&apos;FAMILY&apos;),
        ISCHANGED({!$Record.Phone}), CONTAINS(UPPER({!$Record.Campaign__r.Name}),&apos;FAMILY&apos;)
       )</filterFormula>
        <object>Lead</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
