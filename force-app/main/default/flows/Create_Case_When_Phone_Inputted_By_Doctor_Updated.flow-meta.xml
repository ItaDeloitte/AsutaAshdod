<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>יוצר Case חדש מסוג מידע כללי כאשר השדה Phone_Inputted_By_Doctor מתעדכן (העדכון מתבצע בממשק אסותא דוק)
לשימוש בממשק אסותא דוק- הוקם במסגרת משימה 16934</description>
    <environments>Default</environments>
    <formulas>
        <description>פורמולה של הטקטס שיעודכן בשדה תיעוד (description) בקייס שייפתח</description>
        <name>CaseContentTextFormula</name>
        <dataType>String</dataType>
        <expression>IF(
   ISBLANK({!$Record.Phone_Inputted_By_Doctor__c}), 
   null, 
 &quot;נא לאמת את מספר הטלפון&quot;  
&amp; &quot; &quot; &amp; LEFT({!$Record.Phone_Inputted_By_Doctor__c},3) &amp; &apos;-&apos; &amp; RIGHT({!$Record.Phone_Inputted_By_Doctor__c},7)
&amp; &quot; &quot;&amp;
&quot;מול המטופל ורק לאחר מכן לעדכן בחשבון המטופל&quot; 
)</expression>
    </formulas>
    <interviewLabel>Create Case When Phone Inputted By Doctor Updated {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Create Case When Phone Inputted By Doctor Updated</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
