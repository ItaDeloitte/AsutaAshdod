    <recordCreates>
        <name>CaseGeneralInformation</name>
        <label>יצירת Case מסוג מידע כללי</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <inputAssignments>
            <field>AccountId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Case_subject__c</field>
            <value>
                <stringValue>עדכון פרטים אישיים</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Description</field>
            <value>
                <elementReference>CaseContentTextFormula</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <stringValue>00G8d0000013f3WEAQ</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RecordTypeId</field>
            <value>
                <stringValue>0124J000000hAuUQAU</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>sub_case_subject__c</field>
