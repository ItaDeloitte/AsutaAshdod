                <stringValue>UpdatePhone</stringValue>
            </value>
        </inputAssignments>
        <object>Case</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CaseGeneralInformation</targetReference>
        </connector>
        <filterFormula>(ISNULL({!$Record__Prior.Id}) &amp;&amp; !ISBLANK({!$Record.Phone_Inputted_By_Doctor__c}) ) || ISCHANGED({!$Record.Phone_Inputted_By_Doctor__c})</filterFormula>
        <object>Account</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
