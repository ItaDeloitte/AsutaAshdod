<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>add_one_day</name>
        <label>add one day</label>
        <locationX>726</locationX>
        <locationY>430</locationY>
        <assignmentItems>
            <assignToReference>date_variable</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>date_plus_one</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>count_days</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>count_plus_one</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Day_From_Calendar</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>skip_to_next_day</name>
        <label>skip to next day</label>
        <locationX>956</locationX>
        <locationY>546</locationY>
        <assignmentItems>
            <assignToReference>date_variable</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>date_plus_one</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Day_From_Calendar</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>check_business_day</name>
        <label>check business day</label>
        <locationX>918</locationX>
        <locationY>38</locationY>
        <defaultConnector>
            <targetReference>skip_to_next_day</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not business day</defaultConnectorLabel>
        <rules>
            <name>business</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>business_day</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>count_days</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>input_num_less_1</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>add_one_day</targetReference>
            </connector>
            <label>business day</label>
        </rules>
        <rules>
            <name>finish</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>count_days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>input_num_less_1</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>set_flow_variable</targetReference>
            </connector>
            <label>finish</label>
        </rules>
    </decisions>
    <formulas>
        <name>count_plus_one</name>
        <dataType>Number</dataType>
        <expression>{!count_days} + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>date_plus_one</name>
        <dataType>Date</dataType>
        <expression>{!date_variable} + 1</expression>
    </formulas>
    <formulas>
        <name>input_date_plus_1</name>
        <dataType>Date</dataType>
        <expression>{!input_date} + 1</expression>
    </formulas>
    <formulas>
        <name>input_num_less_1</name>
        <dataType>Number</dataType>
        <expression>{!input_num} - 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>Update_QA_dates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update_QA_dates</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Day_From_Calendar</name>
        <label>Get Day From Calendar</label>
        <locationX>270</locationX>
        <locationY>43</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>check_business_day</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Gregorian_Date__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>date_variable</elementReference>
            </value>
        </filters>
        <object>Calendar1__c</object>
        <outputAssignments>
            <assignToReference>business_day</assignToReference>
            <field>business_day__c</field>
        </outputAssignments>
    </recordLookups>
    <recordUpdates>
        <name>set_flow_variable</name>
        <label>set_flow_variable</label>
        <locationX>1162</locationX>
        <locationY>33</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>input_case_id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Target_date_qa__c</field>
            <value>
                <elementReference>date_variable</elementReference>
            </value>
        </inputAssignments>
        <object>QualityControl__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Get_Day_From_Calendar</targetReference>
        </connector>
    </start>
    <status>Draft</status>
