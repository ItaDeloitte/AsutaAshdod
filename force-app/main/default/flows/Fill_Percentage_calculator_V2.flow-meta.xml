<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign Survey Taken Data</description>
        <name>Assign_Survey_Taken_Data</name>
        <label>Assign Survey Taken Data</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>surveyTakenRecordVariable.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_related_survey_teken_record_id.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>surveyTakenRecordVariable.FillPercentage__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>calculateFillPercentage</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Fill_Percentage_with_the_calculated_fill_Percentage</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Count the number of returned SQRs from Get</description>
        <name>Count_the_number_of_returned_SQRs_from_Get</name>
        <label>Count the number of returned SQRs from Get</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varAnsweredCount</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>get_all_related_SQRs_that_are_isAnswered_AND_not_unShow_and_required</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>total_question</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>Copy_1_of_get_all_related_SQRs_that_are_isAnswered_AND_not_unShow</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_Survey_Taken_Data</targetReference>
        </connector>
    </assignments>
    <description>FB: 06102025- 2115141075- when a response record updated this flow calculates the number of (responses that usShow = false &amp;&amp; isAnswered = ture &amp;&amp; is_required_cuestion = true) / (total number of responses that are shown)</description>
    <environments>Default</environments>
    <formulas>
        <description>Calculates the Fill percentage - number of show and answerd SQRs / Total number of SQRs.</description>
        <name>calculateFillPercentage</name>
        <dataType>String</dataType>
        <expression>TEXT(ROUND(({!varAnsweredCount} * 100) /  {!total_question} , 0)) &amp; &quot;%&quot;</expression>
    </formulas>
    <interviewLabel>Fill Percentage calculator V2 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Fill Percentage calculator V2</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get the total number of all l the related Survey Question responses to Survey Taken trigger record</description>
        <name>Copy_1_of_get_all_related_SQRs_that_are_isAnswered_AND_not_unShow</name>
        <label>get total all related SQRs that are isAnswered AND not unShow</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Count_the_number_of_returned_SQRs_from_Get</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SurveyTaker__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>get_related_survey_teken_record_id.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>UnShow__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>is_required_question__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>SurveyQuestionResponse__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Get all the related Survey Question responses to Survey Taken trigger record</description>
        <name>get_all_related_SQRs_that_are_isAnswered_AND_not_unShow_and_required</name>
        <label>get all related SQRs that are isAnswered AND not unShow and required</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Copy_1_of_get_all_related_SQRs_that_are_isAnswered_AND_not_unShow</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SurveyTaker__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>get_related_survey_teken_record_id.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>UnShow__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>IsAnswered__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>is_required_question__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>SurveyQuestionResponse__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>get related survey taken record id</description>
        <name>get_related_survey_teken_record_id</name>
        <label>get related survey teken record id</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>get_all_related_SQRs_that_are_isAnswered_AND_not_unShow_and_required</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.SurveyTaker__r.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>SurveyTaker__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Update Survey Taken with the calculated value</description>
        <name>Update_Fill_Percentage_with_the_calculated_fill_Percentage</name>
        <label>Update Fill Percentage with the calculated fill Percentage</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>surveyTakenRecordVariable</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>get_related_survey_teken_record_id</targetReference>
        </connector>
        <object>SurveyQuestionResponse__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>related_survey_taken_id</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>survey Taken Record Variable</description>
        <name>surveyTakenRecordVariable</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>SurveyTaker__c</objectType>
    </variables>
    <variables>
        <name>total_question</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
    <variables>
        <name>varAnsweredCount</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
        <value>
            <numberValue>0.0</numberValue>
        </value>
    </variables>
</Flow>
