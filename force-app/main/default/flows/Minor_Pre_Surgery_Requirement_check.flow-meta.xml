    <decisions>
        <description>Determines whether the patient is an adult or a minor.
Additionally, regardless of age, if taking_blood__c is set to True for a medical procedure related to the appointment, the patient must visit the pre-surgery room.</description>
        <name>adult_or_minor</name>
        <label>adult or minor</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>adult_loop</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Taking_Blood_on_Medical_Procedure</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Appointment__r.Medical_Procedure__r.taking_blood__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Pre_Surgery_is_required_set_the_relevant_values_on_the_appointment_related_to_th</targetReference>
            </connector>
            <label>Taking Blood on Medical Procedure</label>
        </rules>
        <rules>
            <name>minor</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Survey__r.SurveyCode__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PreSurgeryMinors</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Responses_for</targetReference>
            </connector>
            <label>minor</label>
        </rules>
    </decisions>
