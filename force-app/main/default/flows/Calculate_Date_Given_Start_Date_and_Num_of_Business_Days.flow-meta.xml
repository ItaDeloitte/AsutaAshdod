<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Find_Due_Date</name>
        <label>מציאת תאריך היעד</label>
        <locationX>50</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>Due_Date</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>date_variable</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Finish_Saturday</name>
        <label>Finish-Friday</label>
        <locationX>314</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>Due_Date</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>date_variable_minus_one</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Subtracone_day</name>
        <label>Subtract one day</label>
        <locationX>1194</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>date_variable</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>date_variable_minus_one</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Number_of_Days</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Subtract_one_day</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>Get_Day_From_Calendar</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>subtract_one_day_but_no_minus</name>
        <label>subtract one day but no minus</label>
        <locationX>622</locationX>
        <locationY>650</locationY>
        <assignmentItems>
            <assignToReference>date_variable</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>date_variable_minus_one</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>Get_Day_From_Calendar</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>if we reached a business day, we will return it. If it&apos;s friday before 14, we will subtract one day. If it&apos;s Saturday or Friday after 14, we will subtract two days.</description>
        <name>check_business_day</name>
        <label>check business day</label>
        <locationX>622</locationX>
        <locationY>242</locationY>
        <defaultConnector>
            <targetReference>Subtracone_day</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Finished</defaultConnectorLabel>
        <rules>
            <name>finish</name>
            <conditionLogic>(1 and 2 and 3) or (2 and 4 and 5)</conditionLogic>
            <conditions>
                <leftValueReference>business_day</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Number_of_Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayoftheWeek</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Friday</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayoftheWeek</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Friday</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Is_It_Weekend</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Find_Due_Date</targetReference>
            </connector>
            <label>finish- if last day is a business day</label>
        </rules>
        <rules>
            <name>finishedsaturday</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Number_of_Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayoftheWeek</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Saturday</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Finish_Saturday</targetReference>
            </connector>
            <label>finished-saturday</label>
        </rules>
        <rules>
            <name>finished_holiday</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Is_It_Weekend</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayoftheWeek</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Saturday</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>business_day</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Number_of_Days</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>subtract_one_day_but_no_minus</targetReference>
            </connector>
            <label>finished-holiday</label>
        </rules>
        <rules>
            <name>Not_Finished_Holiday_or_Shabbat</name>
            <conditionLogic>(1 AND 2 AND 3) OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>Is_It_Weekend</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>business_day</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Number_of_Days</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DayoftheWeek</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Saturday</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>subtract_one_day_but_no_minus</targetReference>
            </connector>
            <label>Not Finished= Holiday or Shabbat</label>
        </rules>
        <rules>
            <name>calendar_day_null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Day_From_Calendar</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>calendar day null</label>
        </rules>
    </decisions>
    <description>מחזיר את התאריך בהתחשב בימי עסקים מתאריך מסוים שניתן להזין בקלט</description>
    <environments>Default</environments>
    <formulas>
        <name>count_plus_one</name>
        <dataType>Number</dataType>
        <expression>{!Count_days} + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>date_variable_minus_one</name>
        <dataType>Date</dataType>
        <expression>{!date_variable} - 1</expression>
    </formulas>
    <formulas>
        <name>date_variable_minus_two</name>
        <dataType>Date</dataType>
        <expression>{!date_variable} - 2</expression>
    </formulas>
    <formulas>
        <name>Four_Days_Less_1</name>
        <dataType>Number</dataType>
        <expression>{!Number_of_4_days} - 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Subtract_one_day</name>
        <dataType>Number</dataType>
        <expression>{!Number_of_Days}-1</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>ספירת ימי עסקים מתאריך מסוים {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Calculate Date Given Start Date and Num of Business Days</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Day_From_Calendar</name>
        <label>Get Day From Calendar</label>
        <locationX>622</locationX>
        <locationY>134</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>check_business_day</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Gregorian_Date__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>date_variable</elementReference>
            </value>
        </filters>
        <object>Calendar1__c</object>
        <outputAssignments>
            <assignToReference>DayoftheWeek</assignToReference>
            <field>Day__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>Is_It_Weekend</assignToReference>
            <field>Weekend__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>business_day</assignToReference>
            <field>business_day__c</field>
        </outputAssignments>
    </recordLookups>
    <start>
        <locationX>496</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Day_From_Calendar</targetReference>
        </connector>
    </start>
    <status>Active</status>
