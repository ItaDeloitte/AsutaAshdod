    <decisions>
        <description>this is added since flow &quot;Triggered_Quality_Control_Create_Or_Update_After_Save&quot; fails if user.managerId is null</description>
        <name>Does_Running_User_Has_Manager</name>
        <label>Does Running User Has Manager?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Add_Mannager_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Running_User_Has_Manager</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$User.ManagerId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Profile_Id_Public_Inquiries</targetReference>
            </connector>
            <label>Yes- Running User Has Manager</label>
        </rules>
    </decisions>
    <decisions>
        <description>just a check to the triggered flow: Triggered- Quality Control- Create Or Update- After Save will not fail after creation of QC</description>
        <name>Found_Public_Inquiries_Admin</name>
        <label>Found Public Inquiries Admin?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>No_Public_Inquiries_Administrator_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Found_Public_Inquiries_Admin</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Public_Inquiries_Administrators</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>fill_the_fields</targetReference>
            </connector>
            <label>Yes- Found Public Inquiries Admin</label>
        </rules>
    </decisions>
