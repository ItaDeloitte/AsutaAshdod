<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Email_Message_Link</name>
        <label>Set Email Message Link</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>rvEmailMessageUpdate.Email_link__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fEmailLink</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessageUpdate.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvEmailMessageTrig.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvEmailMessageUpdate.Automation_name__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fAutomationName</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>IsUpdated</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Set_Task_Assignments</name>
        <label>Set Task Assignments</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>rvTaskCreated.OwnerId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvEmailMessageTrig.Parent.OwnerID__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvTaskCreated.Subject</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fTaskSubject</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>rvTaskCreated.WhatId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>rvEmailMessageTrig.Parent.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Is_Email_Received_by_Rishon_or_Ramat</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Is_Email_Received_by_Rishon_or_Ramat</name>
        <label>Is Email  Received by Rishon or Ramat?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Email_Received_by_Rishon_or_Ramat</name>
            <conditionLogic>1 AND ( 2 OR 3  )</conditionLogic>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.ToAddress</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>rishon.info@assuta.co.il</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.ToAddress</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ramat.info@assuta.co.il</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Email_Message_Link</targetReference>
            </connector>
            <label>Email Received by Rishon or Ramat</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Email_related_to_IVF_Case_Object</name>
        <label>Is Email related to IVF Case Object?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Is_Email_Received_by_Rishon_or_Ramat</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Email_related_to_IVF_Case_Object</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>IVF_Freezing_Eggs</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.ParentId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>0</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Task_Assignments</targetReference>
            </connector>
            <label>Email related to IVF Case Object</label>
        </rules>
    </decisions>
    <description>LA 06 04 2026 Monday 2822293567 PB  Task creation due to email arrival to Flow</description>
    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Auto Update Email Message Change&apos;+&apos; ||| &apos;+&apos;Triggered By:&apos;+ {!TriggeredByAutomationName}</expression>
    </formulas>
    <formulas>
        <name>fEmailLink</name>
        <dataType>String</dataType>
        <expression>&quot;https://assuta.my.salesforce.com/&quot; &amp; {!rvEmailMessageTrig.Id}</expression>
    </formulas>
    <formulas>
        <name>fTaskSubject</name>
        <dataType>String</dataType>
        <expression>&apos;התקבל מייל חדש בנוגע לפנייה מספר : &apos; &amp;  {!rvEmailMessageTrig.Parent.CaseNumber}</expression>
    </formulas>
    <interviewLabel>Auto Update Email Message Change {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Update Email Message Change</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Email_related_to_IVF_Case_Object</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <name>IsUpdated</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>rvEmailMessageTrig</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>EmailMessage</objectType>
    </variables>
    <variables>
        <name>rvEmailMessageUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <objectType>EmailMessage</objectType>
    </variables>
    <variables>
        <name>rvTaskCreated</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Task</objectType>
    </variables>
    <variables>
        <name>TriggeredByAutomationName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
