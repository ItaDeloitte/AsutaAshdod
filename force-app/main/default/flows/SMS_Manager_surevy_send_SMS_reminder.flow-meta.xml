    <recordLookups>
        <description>Retrieve surveys where the appointment date is on the next business day or the day after, the survey code matches, the fill percentage is less than 100%, and either the 48-hour checkbox or the 24-hour checkbox is false.</description>
        <name>Get_survey_taken</name>
        <label>Get survey taken</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>loop_Surveys_Taken_from_Get_survey_taken</targetReference>
        </connector>
        <filterLogic>(1 OR 2) AND (3 AND 4) AND (5 OR 6)</filterLogic>
        <filters>
            <field>appointment_date_formula__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_the_next_buissnes_day_plus_1_day_from_calnedar.Gregorian_Date__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>appointment_date_formula__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_the_next_buissness_day_from_calendar.Gregorian_Date__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>SurveyCode__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>managerSurvey</stringValue>
            </value>
        </filters>
        <filters>
            <field>Fill_Percentage__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>100.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>X48H_SMS_Survey_Reminder__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>X24H_SMS_Survey_Reminder__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>SurveyTaker__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_the_next_buissnes_day_plus_1_day_from_calnedar</name>
        <label>Get the next buissnes day plus 1 day from calnedar</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_survey_taken</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Gregorian_Date__c</field>
            <operator>GreaterThan</operator>
            <value>
                <elementReference>Get_the_next_buissness_day_from_calendar.Gregorian_Date__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>business_day__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Calendar1__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
