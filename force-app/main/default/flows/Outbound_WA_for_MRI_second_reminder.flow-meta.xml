    <formulas>
        <name>Content_f_Mamography</name>
        <dataType>String</dataType>
        <expression>{!over_App_records.firstName} &amp; &quot; שלום, להזכירך, נקבע לך תור ל&quot; &amp; 
{!over_App_records.siteName} &amp; &quot; בכתובת: &quot; &amp; 
{!over_App_records.exactLocationInDomain} &amp; &quot; שיתקיים בתאריך &quot; &amp; 
{!over_App_records.dayDateHour} &amp; &quot;. &quot; &amp; 
BR() &amp; 
&quot;אנא אשרו הגעה בקישור: &quot; &amp; 
{!over_App_records.formtitanArrivalLink} &amp; &quot;.&quot; &amp; 
BR() &amp; 
&quot;ריכזנו עבורך את מגוון השירותים הניתנים במסגרת בריאות השד במרכזי אסותא:&quot; &amp; 
BR() &amp; 
&quot;b-care.assuta.co.il&quot; &amp; 
BR() &amp; 
&quot;בברכה, אסותא מרכזים רפואיים.&quot;</expression>
    </formulas>
    <formulas>
        <name>Content_first_f</name>
        <dataType>String</dataType>
        <expression>{!over_App_records.firstName}&amp;&quot; שלום, להזכירך, נקבע לך תור ל&quot;&amp;{!over_App_records.siteName}&amp;&quot; בכתובת:&quot;&amp; {!over_App_records.SMSAddress}&amp;&quot; שיתקיים בתאריך &quot;&amp;{!over_App_records.dayDateHour}&amp;&quot;. אנא אשרו הגעה בקישור:&quot;&amp; {!over_App_records.formtitanArrivalLink}&amp;&quot;. בברכה, אסותא מרכזים רפואיים.&quot;</expression>
    </formulas>
    <formulas>
        <name>Content_Second_f</name>
        <dataType>String</dataType>
        <expression>{!over_App_records.firstName}&amp;&quot; שלום,&quot; &amp;br()&amp;
&quot;ניסינו להשיגך מספר פעמים על מנת לאשר את הגעתך לבדיקה: &quot;&amp;{!over_App_records.medicalProcedureMarketingName} &amp; br() &amp;
&quot;חשוב מאוד שתאשר/י הגעה בקישור הבא: &quot;&amp;{!over_App_records.formtitanArrivalLink}&amp;&quot;.&quot;&amp;br()&amp;
&quot;במידה ולא יתקבל אישור הגעה בשעתיים הקרובות נאלץ לבטל את התור.&quot; &amp;br()&amp;
&quot;להזכירך, ניתן לזמן ולעדכן תורים לבדיקות השונות באתר אסותא בכתובת:&quot; &amp;br()&amp;
&quot;https://assuta.co.il&quot; &amp;br()&amp;
&quot;בריאות איתנה ובשורות טובות,&quot; &amp;br()&amp;
&quot;אסותא מרכזים רפואיים.&quot;</expression>
    </formulas>
    <formulas>
        <name>DateTime_Now</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
    <formulas>
        <name>From_Phone_f</name>
        <dataType>String</dataType>
