        <expression>now()</expression>
    </formulas>
    <formulas>
        <name>Phone_Number_f</name>
        <dataType>String</dataType>
        <expression>if(mid({!over_App_records.phoneNumber}, 4, 1) = &apos;-&apos;,
&quot;0&quot;+right({!over_App_records.phoneNumber},10),
&quot;0&quot;+right({!over_App_records.phoneNumber},9))</expression>
    </formulas>
    <formulas>
        <name>Today</name>
