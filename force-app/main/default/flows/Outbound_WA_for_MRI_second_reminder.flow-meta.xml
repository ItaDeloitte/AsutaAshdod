    </formulas>
    <formulas>
        <name>Which_Content</name>
        <dataType>String</dataType>
        <expression>if({!over_App_records.domainCode} = &apos;307&apos;, {!Content_f_Mamography}, {!Content_first_f})</expression>
    </formulas>
    <formulas>
