    <decisions>
        <name>Doctor_Approval_For_Shikum_Bait</name>
        <label>Doctor Approval For Shikum Bait?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Emaiil_Message_CCmail</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outgoing</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Shikum_Bait</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Subject</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>אישור מטופל לשיקום בית</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Case_Data_Outgoing</targetReference>
            </connector>
            <label>Outgoing</label>
        </rules>
        <rules>
            <name>Incoming</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Shikum_Bait</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Parent.Case_Status_Shikum_Bait__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending_Doctor_Approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvEmailMessageTrig.Subject</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>אסותא-אישור מטופל לשיקום בית</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Case_Data_Incoming</targetReference>
            </connector>
            <label>Incoming</label>
        </rules>
    </decisions>
