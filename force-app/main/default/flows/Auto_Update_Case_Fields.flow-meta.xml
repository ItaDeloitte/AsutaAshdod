    <description>AM: 28052026- 2942867836- wf to flow. + consolidating other subflow (from 2822298883)</description>
    <environments>Default</environments>
    <formulas>
        <name>fAutomationName</name>
        <dataType>String</dataType>
        <expression>&apos;Auto- Update Case Fields&apos;+&apos; ||| &apos;+&apos; Triggered By: &apos;+{!tvAutomationName}</expression>
    </formulas>
    <formulas>
        <name>fCCAddress</name>
        <dataType>Boolean</dataType>
        <expression>AND( NOT(ISBLANK({!rvEmailMessageTrig.CcAddress})),
          NOT(CONTAINS({!rvEmailMessageTrig.CcAddress}, &quot;;&quot;))
          )</expression>
    </formulas>
    <formulas>
        <name>fMailsaddress</name>
        <dataType>String</dataType>
        <expression>{!rvEmailMessageTrig.ToAddress}+&quot;;&quot;+{!rvEmailMessageTrig.CcAddress}</expression>
    </formulas>
    <formulas>
        <name>fToaddressemailCONTAINS</name>
        <dataType>Boolean</dataType>
        <expression>NOT(CONTAINS({!rvEmailMessageTrig.ToAddress}, &quot;;&quot;))</expression>
    </formulas>
