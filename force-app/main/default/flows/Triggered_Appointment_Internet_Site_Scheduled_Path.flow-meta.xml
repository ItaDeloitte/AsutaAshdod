    <decisions>
        <description>ff</description>
        <name>Send_WA_When_Not_Paid_And_Private_Service</name>
        <label>Send WA When Not Paid? (And Private Service)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_Send_WA</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PaymentStatus__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Valid</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Medical_Procedure__r.Are_services_private__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.PayerFactor__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>מטופל פרטי</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Outbound_WA_for_Surgery</targetReference>
            </connector>
            <label>Yes - Send WA</label>
        </rules>
    </decisions>
    <description>AM: 26102025- 2153485450- הקמת תהליך וואטסאפ להתרעה על ביטול תור שירות פרטי עקב אי תשלום
