    <decisions>
        <description>checks if the related appointment Already_received_recom__c = true. if not it will update to true. and will also connect the case to the appointment</description>
        <name>Recommendation_Already_Received</name>
        <label>Recommendation Already Received?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>New_Or_Update</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No_Recommendation_Not_Received</name>
            <conditionLogic>(1 AND 2 AND 3) OR (4 AND 5 AND 6) OR (7 OR 8 OR 9 OR 10)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Related_Appointment__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Related_Appointment__r.Already_received_recom__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case360__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Close_Reason_Memo__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status_recommendation__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>נסגר ללא טיפול המשך</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status_recommendation__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>חדש</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Referral_Doctor__r.Expertise_1__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>פלסטיקה</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Referral_Doctor__r.Expertise_1__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>כירורגיה כללית</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Referral_Doctor__r.Expertise_2__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>פלסטיקה</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Referral_Doctor__r.Expertise_2__r.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>כירורגיה כללית</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Auto_Update_Appointment_And_Case_On_Recommendations_After_Exam_Change_Flow</targetReference>
            </connector>
            <label>No- Recommendation Not Received</label>
        </rules>
    </decisions>
