    <decisions>
        <name>Is_File_Type</name>
        <label>Is File Type סיכום יעוץ ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Appointment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes_File_type_is</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rvAssutaFileTrig.Appointment__r.RecordType.DeveloperName</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Experts</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvAssutaFileTrig.file_type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>865</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>rvAssutaFileTrig.Portal_Auto_Number__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Consultancy_summary_document_status</targetReference>
            </connector>
            <label>Yes File type is סיכום יעוץ</label>
        </rules>
    </decisions>
