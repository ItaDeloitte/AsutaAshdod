    <start>
        <locationX>1254</locationX>
        <locationY>207</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &apos;Surgeries&apos; &amp;&amp; 
(
       ({!$Record.PaymentsRead__c} = TRUE &amp;&amp;  {!$Record.Kit_approved_signed__c} = FALSE)
||
       ( {!$Record.PayerFactor__r.InsuranceCode__c} = &apos;3&apos; ||  {!$Record.PayerFactor__r.InsuranceCode__c} = &apos;303&apos;) &amp;&amp;
        ISPICKVAL( {!$Record.Commitment_Status__c}, &apos;0&apos; ) &amp;&amp;
        ISPICKVAL( {!$Record.Appointment_Status__c}, &apos;ממתין להתחייבות&apos; ) &amp;&amp;
        ISBLANK( {!$Record.Deductibles__c}) = TRUE &amp;&amp;
        ISBLANK( {!$Record.Deductibles_Hospitalization__c}) = TRUE &amp;&amp;  
        {!$Record.Didkitsent__c} = FALSE &amp;&amp;
        {!$Record.text_for_kit_Formula__c} = &quot;האם עבד&quot;
)</filterFormula>
        <object>Appointment__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>Check_PaymentsRead_c_is_True</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
