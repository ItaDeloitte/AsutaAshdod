<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>הוחלט ליצור RT FLOW שיפעל כאשר נוצר רשומה סוג המסמך הוא שאלון טרום ניתוח באובייקט ASSUTA FILES, יעדכן את שדה SurveyCompletedTimestamp__c באובייקט APPOINTMENT</description>
    <environments>Default</environments>
    <interviewLabel>Assuta files - Update appointment {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Assuta files - Update Survey DateTime in Appointment</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>יעדכן את שדה SurveyCompletedTimestamp__c באובייקט APPOINTMENT</description>
        <name>Update_SurveyCompletedTimestamp_in_Appointment</name>
        <label>Update SurveyCompletedTimestamp in Appointment</label>
        <locationX>774</locationX>
        <locationY>382</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Appointment__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>SurveyCompletedTimestamp__c</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <object>Appointment__c</object>
    </recordUpdates>
    <start>
        <locationX>650</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Update_SurveyCompletedTimestamp_in_Appointment</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>file_type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>808</stringValue>
            </value>
        </filters>
        <object>File__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
