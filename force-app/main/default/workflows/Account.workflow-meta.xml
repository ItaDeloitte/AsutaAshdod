    <rules>
        <fullName>Update preferred channel if blank</fullName>
        <actions>
            <name>Set_use_for_SMS</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Update_preferred_channel_to_SMS</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>If preferred channel is blank and phone is NOT kosher
Activate on GO LIVE</description>
        <formula>NOT(OR(
BEGINS(Phone , &quot;05271&quot;), BEGINS(Phone , &quot;05276&quot;),
BEGINS(Phone , &quot;05484&quot;), BEGINS(Phone , &quot;05485&quot;),
BEGINS(Phone , &quot;05832&quot;), BEGINS(Phone , &quot;05567&quot;),
BEGINS(Phone , &quot;05331&quot;), BEGINS(Phone , &quot;05341&quot;)))
&amp;&amp;
(ISPICKVAL( Preferred_Channel__c , &quot;&quot; ) ||
ISPICKVAL( Preferred_Channel__c , &quot;Unknown&quot; ))
&amp;&amp;

( Use_for_SMS__c &amp;&amp; ISPICKVAL( Preferred_Channel__c , &apos;SMS&apos;)||Use_for_SMS__c &amp;&amp; NOT(sms_disability__c) )
&amp;&amp;
NOT(

NOT( $User.Id = &apos;0054J000002PIdC&apos; || $User.Id = &apos;0054J000002Q8am&apos; || $User.Id = &apos;0054J000002QSkU&apos; || $User.Id = &apos;0054J000004RQEhQAO&apos; || $User.Id = &apos;0054J000000vlO1QAI&apos;) &amp;&amp;
( LastModifiedById&lt;&gt;&apos;0054J000002QSkU&apos; &amp;&amp; CreatedById&lt;&gt;&apos;0054J000002QSkU&apos;)
&amp;&amp;
(( DisableValidation__c = false) ) &amp;&amp;

( CONTAINS(PersonMailingCountry , &quot;ישראל&quot;)
||
ISBLANK(PersonMailingCountry) )
&amp;&amp;
NOT( ISBLANK(Phone ))
&amp;&amp;
(LEN( Phone ) &lt;&gt; 10
||
LEFT( Phone , 1) &lt;&gt; &quot;0&quot;)&amp;&amp; CreatedById &lt;&gt; &apos;2F0014J00000Jp1GHQAZ&apos;

)</formula>
        <triggerType>onCreateOnly</triggerType>
    </rules>
