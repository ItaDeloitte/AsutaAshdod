    <rules>
        <fullName>Update Type of Referral</fullName>
        <actions>
            <name>Update_field_Related_Process_c</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>אם מתקבלת הפניה ממכבי עבור ניתוח (ביצוע פעולה, Hospitalization, חיוב ישיר) 
אז סוג ההפניה יהיה &apos;ניתוחי&apos;</description>
        <formula>ISNEW() &amp;&amp; ( ISPICKVAL( Referral_Type__c , &quot;Hospitalization&quot; ) || ISPICKVAL( Referral_Type__c , &quot;ביצוע פעולה&quot; ) || ISPICKVAL( Referral_Type__c , &quot;חיוב ישיר&quot; ) ) &amp;&amp; NOT(ISPICKVAL(Referral_Type__c , &quot;&quot;))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
