    <rules>
        <fullName>OTP status</fullName>
        <actions>
            <name>Regular_id_needed</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>בתהליך זיהוי רגיל ישר OTP</description>
        <formula>(ISPICKVAL (title__c, &quot;רגיל&quot;) || ISPICKVAL (title__c, &quot;מחמיר&quot;)) &amp;&amp;  ISBLANK(TEXT(status__c))</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>acc-contact email</fullName>
        <actions>
            <name>person_account_email</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>ISCHANGED( AccountId ) || ISNEW() || ISCHANGED(  status__c ) || ISCHANGED(  title__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>basic status</fullName>
        <actions>
            <name>basic_ident</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>תהליך זיהוי בסיסי - מאושר</description>
        <formula>ISPICKVAL (title__c, &quot;בסיסי&quot;) &amp;&amp;  ISBLANK(TEXT(status__c))</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>contact email</fullName>
        <actions>
            <name>contact_email</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>ISCHANGED(  ContactId ) || ISNEW() || ISCHANGED(  status__c ) || ISCHANGED(  title__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>אישור ידני - בסיסי%2Cרגיל</fullName>
        <actions>
            <name>approve_contact</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>AccountContactRelation.Manually_approval__c</field>
            <operation>equals</operation>
            <value>אמת</value>
        </criteriaItems>
        <criteriaItems>
            <field>AccountContactRelation.title__c</field>
            <operation>equals</operation>
            <value>בסיסי,רגיל</value>
        </criteriaItems>
        <criteriaItems>
            <field>AccountContactRelation.status__c</field>
            <operation>notEqual</operation>
            <value>מאושר</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>אישור ידני - מחמיר</fullName>
        <actions>
            <name>approve_contact</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>AccountContactRelation.Manually_approval__c</field>
            <operation>equals</operation>
            <value>אמת</value>
        </criteriaItems>
        <criteriaItems>
            <field>AccountContactRelation.title__c</field>
            <operation>equals</operation>
            <value>מחמיר</value>
        </criteriaItems>
        <criteriaItems>
            <field>AccountContactRelation.status__c</field>
            <operation>equals</operation>
            <value>ממתין לנציג</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
